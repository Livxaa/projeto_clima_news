\n                   <p class=\"text-[10px] font-mono text-[#2A3439]/60 uppercase mt-1\" data-kid=\"194\">Anomaly detected in Sector G-12</p>\n                </div>\n                <div class=\"text-[10px] font-mono font-bold text-[#2A3439]/70 uppercase text-right\" data-kid=\"195\">\n                   14:21:44 UTC\n                </div>\n              </div>\n              <div class=\"bg-white p-6 flex items-center gap-6 group hover:bg-[#F7F7F7] transition-colors\" data-kid=\"196\">\n                <div class=\"w-2 h-2 bg-[#0070FF]\" data-kid=\"197\"></div>\n                <div class=\"flex-1\" data-kid=\"198\">\n                   <p class=\"text-xs font-black uppercase tracking-widest\" data-kid=\"199\">Data Upload Completed</p>\n                   <p class=\"text-[10px] font-mono text-[#2A3439]/60 uppercase mt-1\" data-kid=\"200\">Satellite Transceiver #09 // 4.2 GB transmitted</p>\n                </div>\n                <div class=\"text-[10px] font-mono font-bold text-[#2A3439]/70 uppercase text-right\" data-kid=\"201\">\n                   13:40:11 UTC\n                </div>\n              </div>\n           </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-5 space-y-8\" data-kid=\"202\">\n           <h3 class=\"text-xl font-black uppercase tracking-tighter\" data-kid=\"203\">Atmospheric Indicators</h3>\n           <div class=\"grid grid-cols-2 gap-px bg-[#2A3439] border border-[#2A3439]\" data-kid=\"204\">\n              <div class=\"bg-white p-8 space-y-4\" data-kid=\"205\">\n                 <p class=\"text-[9px] font-black uppercase tracking-widest text-[#2A3439]/40\" data-kid=\"206\">UV Index</p>\n                 <p class=\"text-4xl font-black\" data-kid=\"207\">4.2</p>\n                 <div class=\"h-1 bg-[#F7F7F7]\" data-kid=\"208\">\n                    <div class=\"h-full bg-yellow-400 w-[42%]\" data-kid=\"209\"></div>\n                 </div>\n                 <p class=\"text-[8px] font-mono uppercase text-[#2A3439]/60\" data-kid=\"210\">MODERATE EXPOSURE</p>\n              </div>\n              <div class=\"bg-[#0070FF] p-8 space-y-4 text-white\" data-kid=\"211\">\n                 <p class=\"text-[9px] font-black uppercase tracking-widest text-white/60\" data-kid=\"212\">Air Quality</p>\n                 <p class=\"text-4xl font-black\" data-kid=\"213\">98</p>\n                 <div class=\"h-1 bg-white/20\" data-kid=\"214\">\n                    <div class=\"h-full bg-white w-[98%]\" data-kid=\"215\"></div>\n                 </div>\n                 <p class=\"text-[8px] font-mono uppercase text-white/60\" data-kid=\"216\">OPTIMAL / EXCELLENT</p>\n              </div>\n              <div class=\"bg-white p-8 space-y-4\" data-kid=\"217\">\n                 <p class=\"text-[9px] font-black uppercase tracking-widest text-[#2A3439]/40\" data-kid=\"218\">Wind Vector</p>\n                 <div class=\"flex items-center gap-3\" data-kid=\"219\">\n                    <p class=\"text-4xl font-black\" data-kid=\"220\">12</p>\n                    <span class=\"text-xs font-mono\" data-kid=\"221\">km/h</span>\n                 </div>\n                 <div class=\"flex items-center gap-2\" data-kid=\"222\">\n                    <i class=\"ti ti-arrow-up-right text-[#0070FF]\" data-kid=\"223\"></i>\n                    <p class=\"text-[8px] font-mono uppercase text-[#2A3439]/60\" data-kid=\"224\">NORTH-EAST (45°)</p>\n                 </div>\n              </div>\n              <div class=\"bg-white p-8 space-y-4\" data-kid=\"225\">\n                 <p class=\"text-[9px] font-black uppercase tracking-widest text-[#2A3439]/40\" data-kid=\"226\">Precip. Prob.</p>\n                 <p class=\"text-4xl font-black\" data-kid=\"227\">5%</p>\n                 <div class=\"h-1 bg-[#F7F7F7]\" data-kid=\"228\">\n                    <div class=\"h-full bg-[#0070FF] w-[5%]\" data-kid=\"229\"></div>\n                 </div>\n                 <p class=\"text-[8px] font-mono uppercase text-[#2A3439]/60\" data-kid=\"230\">STABLE CONDITIONS</p>\n              </div>\n           </div>\n        </div>\n      </section>\n\n      \n      <footer class=\"pt-20 pb-10 flex flex-col md:flex-row justify-between items-center gap-8 hairline-t opacity-40\" data-kid=\"231\">\n        <p class=\"text-[10px] font-mono uppercase font-bold\" data-kid=\"232\">© 2024 METEO.SWISS FEDERAL DATA NETWORK // ZURICH HEADQUARTERS</p>\n        <div class=\"flex gap-8 text-[10px] font-black uppercase tracking-widest\" data-kid=\"233\">\n           <a href=\"#\" class=\"hover:text-[#0070FF]\" data-kid=\"234\">Privacy</a>\n           <a href=\"#\" class=\"hover:text-[#0070FF]\" data-kid=\"235\">Terms</a>\n           <a href=\"#\" class=\"hover:text-[#0070FF]\" data-kid=\"236\">Contact Ops</a>\n        </div>\n      </footer>\n    </div>\n  </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"237\"></script>\n<script data-kid=\"238\">\n  document.addEventListener('DOMContentLoaded', () => {\n    // Entrance animations\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 1.2 }});\n\n    tl.from(\"#sidebar\", { x: -100, opacity: 0, duration: 1 })\n      .from(\".stat-reveal\", { y: 30, opacity: 0, stagger: 0.1 }, \"-=0.5\")\n      .from(\"#hero-stat\", { scale: 0.98, opacity: 0 }, \"-=0.8\")\n      .from(\"#live-chart\", { y: 50, opacity: 0 }, \"-=0.8\");\n\n    // Chart animation\n    gsap.to(\".chart-line\", {\n      strokeDashoffset: 0,\n      duration: 2.5,\n      delay: 1.5,\n      ease: \"power2.inOut\"\n    });\n\n    gsap.to(\".chart-area\", {\n      opacity: 1,\n      duration: 1.5,\n      delay: 3,\n      ease: \"power1.inOut\"\n    });\n\n    // Number counting effect for main temp\n    const tempObj = { value: 0 };\n    gsap.to(tempObj, {\n      value: 21.4,\n      duration: 2,\n      delay: 1,\n      ease: \"power3.out\",\n      onUpdate: () => {\n        document.getElementById('current-temp').innerText = tempObj.value.toFixed(1);\n      }\n    });\n  });\n</script>\n",
