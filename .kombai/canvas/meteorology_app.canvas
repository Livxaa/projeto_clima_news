          <div class=\"log-row grid grid-cols-[60px_1.2fr_1fr_1.5fr_1.2fr_1.2fr] px-8 py-6 hover:bg-[#0070FF]/5 transition-colors items-center font-mono group bg-[#F7F7F7]/40\" data-kid=\"145\">\n                        <div class=\"flex items-center\" data-kid=\"146\">\n                            <span class=\"status-dot opacity-20\" data-kid=\"147\"></span>\n                        </div>\n                        <div class=\"text-[14px] text-[#2A3439]/50 tracking-tighter\" data-kid=\"148\">2024.05.24</div>\n                        <div class=\"text-[14px] font-bold tracking-tighter\" data-kid=\"149\">13:50:00</div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"150\">\n                            <span class=\"text-2xl font-black text-[#0070FF] tracking-tighter\" data-kid=\"151\">21.82</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"152\">DEG_CELSIUS</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"153\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"154\">50.2</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"155\">%_RH</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"156\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"157\">1012.2</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"158\">HPA</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"log-row grid grid-cols-[60px_1.2fr_1fr_1.5fr_1.2fr_1.2fr] px-8 py-6 hover:bg-[#0070FF]/5 transition-colors items-center font-mono group\" data-kid=\"159\">\n                        <div class=\"flex items-center\" data-kid=\"160\">\n                            <span class=\"status-dot\" data-kid=\"161\"></span>\n                        </div>\n                        <div class=\"text-[14px] text-[#2A3439]/50 tracking-tighter\" data-kid=\"162\">2024.05.24</div>\n                        <div class=\"text-[14px] font-bold tracking-tighter\" data-kid=\"163\">13:45:11</div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"164\">\n                            <span class=\"text-2xl font-black text-[#0070FF] tracking-tighter\" data-kid=\"165\">21.75</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"166\">DEG_CELSIUS</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"167\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"168\">50.5</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"169\">%_RH</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"170\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"171\">1012.0</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"172\">HPA</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"mt-16 border border-[#2A3439] bg-white grid grid-cols-12 overflow-hidden\" data-kid=\"173\">\n                <div class=\"col-span-4 p-8 border-r border-[#2A3439] flex flex-col justify-between h-48\" data-kid=\"174\">\n                    <div class=\"flex flex-col gap-6\" data-kid=\"175\">\n                        <div class=\"flex flex-col gap-1\" data-kid=\"176\">\n                            <span class=\"text-[10px] font-black text-[#2A3439]/40 uppercase tracking-widest\" data-kid=\"177\">Global Sync Status</span>\n                            <div class=\"flex items-center gap-3\" data-kid=\"178\">\n                                <span class=\"text-xl font-black tracking-tighter\" data-kid=\"179\">NORMAL_OP</span>\n                                <span class=\"bg-[#0070FF] text-white text-[9px] font-black px-1.5 py-0.5 tracking-widest\" data-kid=\"180\">ACTIVE</span>\n                            </div>\n                        </div>\n                        <div class=\"flex flex-col gap-1\" data-kid=\"181\">\n                            <span class=\"text-[10px] font-black text-[#2A3439]/40 uppercase tracking-widest\" data-kid=\"182\">Data Integrity Score</span>\n                            <span class=\"text-xl font-black tracking-tighter text-[#0070FF]\" data-kid=\"183\">99.98%</span>\n                        </div>\n                    </div>\n                    <p class=\"text-[9px] font-bold text-[#2A3439]/30 uppercase tracking-[0.3em]\" data-kid=\"184\">STRATO_SYSTEMS_CORE_v4.2</p>\n                </div>\n\n                <div class=\"col-span-8 flex flex-col justify-between\" data-kid=\"185\">\n                    <div class=\"p-8 flex justify-between items-center border-b border-[#2A3439] bg-[#F7F7F7]/20\" data-kid=\"186\">\n                        <div class=\"flex items-center gap-12\" data-kid=\"187\">\n                            <div class=\"flex flex-col\" data-kid=\"188\">\n                                <span class=\"text-[9px] font-black text-[#2A3439]/40 uppercase tracking-[0.3em] mb-1\" data-kid=\"189\">Current Page</span>\n                                <span class=\"text-3xl font-black tracking-tighter\" data-kid=\"190\">001 <span class=\"text-[#2A3439]/20\" data-kid=\"191\">/ 592</span></span>\n                            </div>\n                            <div class=\"w-px h-12 bg-[#2A3439]/10\" data-kid=\"192\"></div>\n                            <div class=\"flex flex-col text-right\" data-kid=\"193\">\n                                <span class=\"text-[9px] font-black text-[#2A3439]/40 uppercase tracking-[0.3em] mb-1\" data-kid=\"194\">Entries / Page</span>\n                                <span class=\"text-3xl font-black tracking-tighter\" data-kid=\"195\">25</span>\n                            </div>\n                        </div>\n                        <div class=\"flex border border-[#2A3439] overflow-hidden\" data-kid=\"196\">\n                            <button class=\"w-16 h-16 flex items-center justify-center border-r border-[#2A3439] hover:bg-[#2A3439] hover:text-white transition-all disabled:opacity-20\" disabled data-kid=\"197\">\n                                <i class=\"ti ti-arrow-left text-xl\" data-kid=\"198\"></i>\n                            </button>\n                            <button class=\"w-16 h-16 flex items-center justify-center hover:bg-[#2A3439] hover:text-white transition-all\" data-kid=\"199\">\n                                <i class=\"ti ti-arrow-right text-xl\" data-kid=\"200\"></i>\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"flex divide-x divide-[#2A3439] h-full\" data-kid=\"201\">\n                        <div class=\"flex-1 flex items-center justify-center text-[11px] font-black uppercase tracking-widest hover:bg-[#2A3439] hover:text-white transition-all cursor-pointer\" data-kid=\"202\">Jump to Record</div>\n                        <div class=\"flex-1 flex items-center justify-center text-[11px] font-black uppercase tracking-widest hover:bg-[#2A3439] hover:text-white transition-all cursor-pointer\" data-kid=\"203\">Live Analytics</div>\n                        <div class=\"flex-1 flex items-center justify-center text-[11px] font-black uppercase tracking-widest hover:bg-[#2A3439] hover:text-white transition-all cursor-pointer\" data-kid=\"204\">Full Report</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"205\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"206\"></script>\n<script data-kid=\"207\">\n    document.addEventListener('DOMContentLoaded', () => {\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Animate rows\n        gsap.to(\".log-row\", {\n            opacity: 1,\n            y: 0,\n            duration: 0.8,\n            stagger: 0.1,\n            ease: \"expo.out\",\n            scrollTrigger: {\n                trigger: \"#log-grid-container\",\n                start: \"top 85%\"\n            }\n        });\n\n        // Parallax effect for the cloud image in sidebar\n        gsap.to(\"#sidebar-cloud-img\", {\n            y: -30,\n            scrollTrigger: {\n                trigger: \"main\",\n                start: \"top top\",\n                end: \"bottom bottom\",\n                scrub: 1\n            }\n        });\n\n        // Header punch animation\n        gsap.from(\"h2\", {\n            y: 50,\n            opacity: 0,\n            duration: 1.2,\n            ease: \"expo.out\",\n            delay: 0.2\n        });\n\n        // Hover effect for sidecam widget\n        const camWidget = document.querySelector('.relative.h-\\\\[160px\\\\]');\n        if (camWidget) {\n            camWidget.addEventListener('mouseenter', () => {\n                gsap.to(\"#sidebar-cloud-img\", { scale: 1.1, duration: 1, ease: \"power2.out\" });\n            });\n            camWidget.addEventListener('mouseleave', () => {\n                gsap.to(\"#sidebar-cloud-img\", { scale: 1, duration: 1, ease: \"power2.out\" });\n            });\n        }\n    });\n</script>",
