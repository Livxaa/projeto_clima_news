      "html": "\n<div class=\"flex min-h-screen bg-[#F7F7F7] font-sans text-[#2A3439] selection:bg-[#0070FF] selection:text-white\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Roboto+Mono:wght@400;500;700&display=swap');\n        \n        :root {\n            --color-bg: #F7F7F7;\n            --color-dark: #2A3439;\n            --color-blue: #0070FF;\n        }\n\n        .font-mono { font-family: 'Roboto Mono', monospace; }\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 4px; }\n        ::-webkit-scrollbar-track { background: var(--color-bg); }\n        ::-webkit-scrollbar-thumb { background: var(--color-dark); }\n\n        .masonry-grid {\n            display: grid;\n            grid-template-columns: repeat(12, 1fr);\n            grid-auto-rows: minmax(100px, auto);\n            gap: 1rem;\n        }\n\n        .bg-grid {\n            background-image: \n                linear-gradient(to right, var(--color-dark) 1px, transparent 1px),\n                linear-gradient(to bottom, var(--color-dark) 1px, transparent 1px);\n            background-size: 100px 100px;\n            background-position: top left;\n            opacity: 0.03;\n        }\n\n        .hairline-border {\n            border: 1px solid var(--color-dark);\n        }\n\n        .hairline-b { border-bottom: 1px solid var(--color-dark); }\n        .hairline-r { border-right: 1px solid var(--color-dark); }\n        .hairline-t { border-top: 1px solid var(--color-dark); }\n        .hairline-l { border-left: 1px solid var(--color-dark); }\n\n        .stagger-card { opacity: 0; transform: translateY(20px); }\n        .alert-pulse { animation: alert-flash 1s infinite; }\n        @keyframes alert-flash { \n            0%, 100% { background-color: #0070FF; color: white; } \n            50% { background-color: #2A3439; color: white; } \n        }\n    </style>\n\n    \n    <aside class=\"w-72 hairline-r flex flex-col sticky top-0 h-screen shrink-0 bg-[#F7F7F7] z-50\" data-kid=\"2\">\n        <div class=\"p-8 hairline-b bg-white\" data-kid=\"3\">\n            <div class=\"flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-6 h-6 bg-black flex items-center justify-center\" data-kid=\"5\">\n                    <div class=\"w-3 h-3 bg-white\" data-kid=\"6\"></div>\n                </div>\n                <h1 class=\"text-xl font-black uppercase tracking-tighter leading-none\" data-kid=\"7\">METEO.SWISS</h1>\n            </div>\n        </div>\n\n        <nav class=\"flex-1 overflow-y-auto\" data-kid=\"8\">\n            <div class=\"p-8\" data-kid=\"9\">\n                <p class=\"text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-6\" data-kid=\"10\">Navigation</p>\n                <div class=\"space-y-1\" data-kid=\"11\">\n                    <a href=\"#\" class=\"group flex items-center justify-between py-3 transition-all hover:bg-white -mx-2 px-2 border-l-2 border-transparent hover:border-l-[var(--color-blue)]\" data-kid=\"12\">\n                        <span class=\"text-xs font-bold uppercase tracking-widest group-hover:text-[var(--color-blue)]\" data-kid=\"13\">01 Dashboard</span>\n                        <i class=\"ti ti-arrow-right text-[10px] opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all\" data-kid=\"14\"></i>\n                    </a>\n                    <a href=\"#\" class=\"group flex items-center justify-between py-3 transition-all hover:bg-white -mx-2 px-2 border-l-2 border-transparent hover:border-l-[var(--color-blue)]\" data-kid=\"15\">\n                        <span class=\"text-xs font-bold uppercase tracking-widest group-hover:text-[var(--color-blue)]\" data-kid=\"16\">02 Temperature Logs</span>\n                        <i class=\"ti ti-arrow-right text-[10px] opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all\" data-kid=\"17\"></i>\n                    </a>\n                    <div class=\"flex items-center justify-between py-3 text-[var(--color-blue)] bg-white -mx-2 px-4 hairline-border border-r-0 border-l-4 border-l-[var(--color-blue)]\" data-kid=\"18\">\n                        <span class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"19\">03 Detailed Reports</span>\n                        <div class=\"w-2 h-2 bg-[var(--color-blue)]\" data-kid=\"20\"></div>\n                    </div>\n                    <a href=\"#\" class=\"group flex items-center justify-between py-3 transition-all\" data-kid=\"21\">\n                        <span class=\"text-xs font-bold uppercase tracking-widest group-hover:text-[var(--color-blue)]\" data-kid=\"22\">04 Satellite Data</span>\n                        <i class=\"ti ti-arrow-right text-[10px] opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all\" data-kid=\"23\"></i>\n                    </a>\n                    <a href=\"#\" class=\"group flex items-center justify-between py-3 transition-all\" data-kid=\"24\">\n                        <span class=\"text-xs font-bold uppercase tracking-widest group-hover:text-[var(--color-blue)]\" data-kid=\"25\">05 Pressure Mapping</span>\n                        <i class=\"ti ti-arrow-right text-[10px] opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all\" data-kid=\"26\"></i>\n                    </a>\n                </div>\n            </div>\n\n            <div class=\"p-8 hairline-t\" data-kid=\"27\">\n                <p class=\"text-[10px] font-bold uppercase tracking-[0.2em] opacity-40 mb-6\" data-kid=\"28\">Archive</p>\n                <div class=\"space-y-4\" data-kid=\"29\">\n                    <div class=\"font-mono text-[10px]\" data-kid=\"30\">\n                        <p class=\"opacity-60 mb-1 underline\" data-kid=\"31\">HIST_Q1_2026.DAT</p>\n                        <p class=\"opacity-60 mb-1 underline\" data-kid=\"32\">HIST_Q4_2025.DAT</p>\n                        <p class=\"opacity-60 mb-1 underline\" data-kid=\"33\">GLOBAL_TEMP_ANN.PDF</p>\n                    </div>\n                </div>\n            </div>\n        </nav>\n\n        <div class=\"p-8 hairline-t\" data-kid=\"34\">\n            <div class=\"flex items-center gap-4\" data-kid=\"35\">\n                <div class=\"w-10 h-10 hairline-border bg-white flex items-center justify-center\" data-kid=\"36\">\n                    <i class=\"ti ti-user text-lg\" data-kid=\"37\"></i>\n                </div>\n                <div data-kid=\"38\">\n                    <p class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"39\">DR. L. MÜLLER</p>\n                    <p class=\"text-[10px] font-mono opacity-50\" data-kid=\"40\">CH-METEO-991</p>\n                </div>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col overflow-hidden\" data-kid=\"41\">\n        \n        <header class=\"h-20 hairline-b flex items-center justify-between px-12 shrink-0 bg-white/50 backdrop-blur-sm z-40\" data-kid=\"42\">\n            <div class=\"flex items-center gap-6 text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"43\">\n                <span class=\"opacity-40\" data-kid=\"44\">Main</span>\n                <i class=\"ti ti-chevron-right text-[8px] opacity-20\" data-kid=\"45\"></i>\n                <span class=\"opacity-40\" data-kid=\"46\">Analysis</span>\n                <i class=\"ti ti-chevron-right text-[8px] opacity-20\" data-kid=\"47\"></i>\n                <span class=\"text-[var(--color-blue)]\" data-kid=\"48\">Detailed Reports</span>\n            </div>\n            <div class=\"flex items-center gap-8\" data-kid=\"49\">\n                <div class=\"flex items-center gap-2 font-mono text-[10px]\" data-kid=\"50\">\n                    <span class=\"w-1.5 h-1.5 bg-green-500\" data-kid=\"51\"></span>\n                    <span data-kid=\"52\">SYSTEM_OK</span>\n                </div>\n                <div class=\"font-mono text-[10px] tabular-nums\" data-kid=\"53\">\n                    11.06.2026 — 14:48:22 UTC\n                </div>\n            </div>\n        </header>\n\n        \n        <div class=\"flex-1 overflow-y-auto p-12 relative\" data-kid=\"54\">\n            <div class=\"absolute inset-0 bg-grid pointer-events-none\" data-kid=\"55\"></div>\n            \n            <div class=\"mb-12 alert-pulse hairline-border p-4 flex items-center justify-between\" data-kid=\"56\">\n                <div class=\"flex items-center gap-4\" data-kid=\"57\">\n                    <i class=\"ti ti-alert-triangle-filled\" data-kid=\"58\"></i>\n                    <span class=\"text-[10px] font-bold uppercase tracking-[0.3em]\" data-kid=\"59\">Critical: Anomalous Pressure Gradient Detected in Cluster C-12</span>\n                </div>\n                <div class=\"font-mono text-[10px] underline cursor-pointer\" data-kid=\"60\">VIEW DATASET</div>\n            </div>\n\n            \n            <div class=\"mb-16 relative\" data-kid=\"61\">\n                <div class=\"flex items-start justify-between\" data-kid=\"62\">\n                    <div data-kid=\"63\">\n                        <div class=\"flex items-center gap-4 mb-6\" data-kid=\"64\">\n                            <span class=\"text-[10px] font-mono bg-[var(--color-dark)] text-white px-2 py-0.5 tracking-tighter\" data-kid=\"65\">REF: CH-2026-Q2</span>\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"66\">Classification: Level 1-A / Swiss Alpha</span>\n                        </div>\n                        <h2 class=\"text-[7rem] font-black uppercase tracking-[-0.04em] leading-[0.85] mb-8\" data-kid=\"67\">\n                            Analytical <br data-kid=\"68\"><span class=\"text-[var(--color-blue)]\" data-kid=\"69\">Sequence 026</span>\n                        </h2>\n                    </div>\n                    <div class=\"text-right flex flex-col items-end gap-2\" data-kid=\"70\">\n                        <div class=\"w-16 h-16 hairline-border flex items-center justify-center mb-4\" data-kid=\"71\">\n                            <i class=\"ti ti-microscope text-2xl\" data-kid=\"72\"></i>\n                        </div>\n                        <span class=\"text-[10px] font-mono opacity-50\" data-kid=\"73\">v4.0.2 Stable Build</span>\n                    </div>\n                </div>\n                <div class=\"mt-8 flex items-end justify-between border-t border-[var(--color-dark)] pt-8\" data-kid=\"74\">\n                    <p class=\"text-xs font-bold uppercase tracking-[0.2em] opacity-60 max-w-xl leading-relaxed\" data-kid=\"75\">\n                        Comprehensive meteorological decomposition. Cross-referencing atmospheric pressure anomalies with relative humidity distribution and solar radiation trends for the Alpine region. Synchronized via global sensor network.\n                    </p>\n                    <div class=\"flex gap-4\" data-kid=\"76\">\n                        <button class=\"hairline-border px-6 py-2 text-[10px] font-bold uppercase tracking-widest hover:bg-[var(--color-dark)] hover:text-white transition-all\" data-kid=\"77\">Export CSV</button>\n                        <button class=\"bg-[var(--color-blue)] text-white px-6 py-2 text-[10px] font-bold uppercase tracking-widest hover:brightness-110 transition-all\" data-kid=\"78\">Run Full Report</button>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"masonry-grid\" data-kid=\"79\">\n                \n                <div class=\"col-span-8 row-span-4 hairline-border p-10 bg-white stagger-card\" data-kid=\"80\">\n                    <div class=\"flex justify-between items-start mb-12\" data-kid=\"81\">\n                        <div data-kid=\"82\">\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"83\">Analysis / Data Integrity</span>\n                            <h3 class=\"text-3xl font-black uppercase tracking-tighter mt-1\" data-kid=\"84\">Confidence Factor</h3>\n                        </div>\n                        <div class=\"font-mono text-[10px] p-2 bg-[var(--color-bg)] hairline-border\" data-kid=\"85\">\n                            LOG_ID: SV-8812\n                        </div>\n                    </div>\n                    \n                    <div class=\"flex items-baseline gap-4 mb-12\" data-kid=\"86\">\n                        <span class=\"text-[12rem] font-black tracking-[-0.05em] leading-none\" data-kid=\"87\">84.2</span>\n                        <span class=\"text-4xl font-black\" data-kid=\"88\">%</span>\n                    </div>\n\n                    <div class=\"mt-auto\" data-kid=\"89\">\n                        <div class=\"flex justify-between items-end mb-4\" data-kid=\"90\">\n                            <p class=\"text-[10px] font-bold uppercase tracking-widest opacity-60\" data-kid=\"91\">Vector Distribution</p>\n                            <span class=\"text-[10px] font-mono text-[var(--color-blue)]\" data-kid=\"92\">SIGMA: 0.94</span>\n                        </div>\n                        \n                        <div class=\"h-12 flex hairline-border overflow-hidden\" data-kid=\"93\">\n                            <div class=\"h-full bg-[var(--color-blue)]\" style=\"width: 60%\" data-kid=\"94\"></div>\n                            <div class=\"h-full bg-[var(--color-dark)]\" style=\"width: 25%\" data-kid=\"95\"></div>\n                            <div class=\"h-full bg-[#E5E5E5]\" style=\"width: 15%\" data-kid=\"96\"></div>\n                        </div>\n                        <div class=\"mt-6 flex gap-12\" data-kid=\"97\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"98\">\n                                <div class=\"w-3 h-3 bg-[var(--color-blue)]\" data-kid=\"99\"></div> \n                                <span class=\"text-[9px] font-bold uppercase tracking-widest\" data-kid=\"100\">High Reliability</span>\n                            </div>\n                            <div class=\"flex items-center gap-3\" data-kid=\"101\">\n                                <div class=\"w-3 h-3 bg-[var(--color-dark)]\" data-kid=\"102\"></div> \n                                <span class=\"text-[9px] font-bold uppercase tracking-widest\" data-kid=\"103\">Nominal</span>\n                            </div>\n                            <div class=\"flex items-center gap-3\" data-kid=\"104\">\n                                <div class=\"w-3 h-3 bg-[#E5E5E5] hairline-border\" data-kid=\"105\"></div> \n                                <span class=\"text-[9px] font-bold uppercase tracking-widest\" data-kid=\"106\">Deviation</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-4 row-span-4 bg-[var(--color-dark)] text-white p-8 flex flex-col justify-between stagger-card\" data-kid=\"107\">\n                    <header data-kid=\"108\">\n                        <div class=\"flex justify-between items-center mb-6\" data-kid=\"109\">\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-60\" data-kid=\"110\">Alert System</span>\n                            <div class=\"w-2 h-2 bg-red-500 animate-pulse\" data-kid=\"111\"></div>\n                        </div>\n                        <h3 class=\"text-4xl font-black uppercase tracking-tighter leading-none mb-6\" data-kid=\"112\">Anomaly <br data-kid=\"113\">Detection</h3>\n                        <div class=\"p-4 bg-white/5 hairline-border border-white/10\" data-kid=\"114\">\n                            <p class=\"text-[10px] font-mono leading-relaxed\" data-kid=\"115\">\n                                Critical deviation in stratospheric thermal profiles identified at coordinate [47.37, 8.54].\n                            </p>\n                        </div>\n                    </header>\n                    <div class=\"mt-8 border-t border-white/10 pt-8 flex-1\" data-kid=\"116\">\n                        <div class=\"space-y-6 font-mono text-[11px]\" data-kid=\"117\">\n                            <div class=\"flex justify-between border-b border-white/5 pb-2\" data-kid=\"118\">\n                                <span class=\"opacity-40\" data-kid=\"119\">STATION_ID</span>\n                                <span data-kid=\"120\">ALPHA-09</span>\n                            </div>\n                            <div class=\"flex justify-between border-b border-white/5 pb-2\" data-kid=\"121\">\n                                <span class=\"opacity-40\" data-kid=\"122\">MAGNITUDE</span>\n                                <span class=\"text-[var(--color-blue)] font-bold\" data-kid=\"123\">+2.45 σ</span>\n                            </div>\n                            <div class=\"flex justify-between border-b border-white/5 pb-2\" data-kid=\"124\">\n                                <span class=\"opacity-40\" data-kid=\"125\">TEMP_VAR</span>\n                                <span class=\"text-red-400\" data-kid=\"126\">+4.2°C</span>\n                            </div>\n                            <div class=\"flex justify-between border-b border-white/5 pb-2\" data-kid=\"127\">\n                                <span class=\"opacity-40\" data-kid=\"128\">DURATION</span>\n                                <span data-kid=\"129\">00:12:44</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-8 space-y-3\" data-kid=\"130\">\n                        <button class=\"bg-[var(--color-blue)] text-white w-full py-3 text-[10px] font-bold uppercase tracking-widest hover:brightness-110 transition-all\" data-kid=\"131\">\n                            Initiate Re-Calibration\n                        </button>\n                        <button class=\"hairline-border border-white/20 w-full py-3 text-[10px] font-bold uppercase tracking-widest hover:bg-white hover:text-[var(--color-dark)] transition-all\" data-kid=\"132\">\n                            Download Raw Log\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-4 row-span-2 hairline-border p-8 bg-white stagger-card\" data-kid=\"133\">\n                    <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"134\">Relative Humidity</span>\n                    <div class=\"mt-6 flex items-baseline gap-2\" data-kid=\"135\">\n                        <span class=\"text-5xl font-black font-mono\" data-kid=\"136\">62</span>\n                        <span class=\"text-lg font-bold opacity-60\" data-kid=\"137\">%</span>\n                    </div>\n                    <div class=\"mt-8\" data-kid=\"138\">\n                        <div class=\"h-1 bg-[var(--color-dark)]/5 w-full relative\" data-kid=\"139\">\n                            <div class=\"absolute inset-y-0 left-0 bg-[var(--color-blue)]\" style=\"width: 62%\" data-kid=\"140\"></div>\n                        </div>\n                        <div class=\"mt-4 flex justify-between font-mono text-[8px] opacity-40\" data-kid=\"141\">\n                            <span data-kid=\"142\">0%</span>\n                            <span data-kid=\"143\">50%</span>\n                            <span data-kid=\"144\">100%</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-4 row-span-2 hairline-border p-8 bg-white stagger-card flex flex-col justify-between\" data-kid=\"145\">\n                    <div data-kid=\"146\">\n                        <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"147\">Cloud Density Matrix</span>\n                        \n                        <div class=\"h-4 flex hairline-border mt-6\" data-kid=\"148\">\n                            <div class=\"h-full bg-[var(--color-dark)]\" style=\"width: 45%\" data-kid=\"149\"></div>\n                            <div class=\"h-full bg-[var(--color-blue)]\" style=\"width: 35%\" data-kid=\"150\"></div>\n                            <div class=\"h-full bg-white\" style=\"width: 20%\" data-kid=\"151\"></div>\n                        </div>\n                    </div>\n                        <div class=\"mt-6 grid grid-cols-2 gap-y-4\" data-kid=\"152\">\n                            <div class=\"flex items-center gap-2 text-[9px] font-bold uppercase\" data-kid=\"153\">\n                                <div class=\"w-1.5 h-1.5 bg-[var(--color-dark)]\" data-kid=\"154\"></div> Cumulus (45%)\n                            </div>\n                            <div class=\"flex items-center gap-2 text-[9px] font-bold uppercase\" data-kid=\"155\">\n                                <div class=\"w-1.5 h-1.5 bg-[var(--color-blue)]\" data-kid=\"156\"></div> Stratus (35%)\n                            </div>\n                            <div class=\"flex items-center gap-2 text-[9px] font-bold uppercase\" data-kid=\"157\">\n                                <div class=\"w-1.5 h-1.5 bg-white border border-[var(--color-dark)]\" data-kid=\"158\"></div> Cirrus (20%)\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-4 row-span-2 hairline-border p-8 bg-white stagger-card\" data-kid=\"159\">\n                    <div class=\"flex justify-between items-center mb-8\" data-kid=\"160\">\n                        <div data-kid=\"161\">\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"162\">Barometric Trend</span>\n                            <p class=\"text-[8px] font-mono opacity-30 mt-1\" data-kid=\"163\">S/N: 991-BP-X</p>\n                        </div>\n                        <i class=\"ti ti-activity-heartbeat text-[var(--color-blue)] text-xl\" data-kid=\"164\"></i>\n                    </div>\n                    <div class=\"h-24 w-full mb-8 relative\" data-kid=\"165\">\n                        <svg viewBox=\"0 0 400 120\" class=\"w-full h-full fill-none stroke-[var(--color-blue)] stroke-[2]\" data-kid=\"166\">\n                            <path d=\"M0,90 C50,90 70,30 100,60 C130,90 150,110 200,80 C250,50 280,10 320,40 C360,70 380,80 400,20\" data-kid=\"167\"></path>\n                            <path d=\"M0,90 C50,90 70,30 100,60 C130,90 150,110 200,80 C250,50 280,10 320,40 C360,70 380,80 400,20 L400,120 L0,120 Z\" class=\"fill-[var(--color-blue)]/5 stroke-none\" data-kid=\"168\"></path>\n                            <circle cx=\"400\" cy=\"20\" r=\"3\" fill=\"white\" stroke=\"var(--color-blue)\" stroke-width=\"2\" data-kid=\"169\"></circle>\n                        </svg>\n                    </div>\n                    <div class=\"flex justify-between font-mono text-[11px] border-t border-[var(--color-dark)]/5 pt-4\" data-kid=\"170\">\n                        <div data-kid=\"171\">\n                            <span class=\"block text-[9px] opacity-40 uppercase tracking-widest\" data-kid=\"172\">Atm Pressure</span>\n                            <span class=\"font-bold\" data-kid=\"173\">1013.25 hPa</span>\n                        </div>\n                        <div class=\"text-right\" data-kid=\"174\">\n                            <span class=\"block text-[9px] opacity-40 uppercase tracking-widest\" data-kid=\"175\">Volatility</span>\n                            <span class=\"font-bold text-green-600\" data-kid=\"176\">L-STABLE</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-6 row-span-3 hairline-border p-8 bg-white stagger-card\" data-kid=\"177\">\n                    <div class=\"flex justify-between items-start mb-12\" data-kid=\"178\">\n                        <div data-kid=\"179\">\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"180\">Solar Metrics</span>\n                            <h3 class=\"text-2xl font-black uppercase tracking-tighter mt-1\" data-kid=\"181\">Radiation Intensity</h3>\n                        </div>\n                        <i class=\"ti ti-sun text-2xl\" data-kid=\"182\"></i>\n                    </div>\n                    <div class=\"grid grid-cols-2 gap-12\" data-kid=\"183\">\n                        <div class=\"flex flex-col justify-end\" data-kid=\"184\">\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 mb-2\" data-kid=\"185\">Peak UV Index</span>\n                            <span class=\"text-7xl font-black font-mono leading-none\" data-kid=\"186\">08</span>\n                            <div class=\"mt-4 h-1 bg-[var(--color-dark)]/5\" data-kid=\"187\">\n                                <div class=\"h-full bg-orange-500 w-[80%]\" data-kid=\"188\"></div>\n                            </div>\n                        </div>\n                        <div class=\"flex flex-col justify-end\" data-kid=\"189\">\n                            <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 mb-2\" data-kid=\"190\">Watts / m²</span>\n                            <span class=\"text-7xl font-black font-mono leading-none\" data-kid=\"191\">840</span>\n                            <div class=\"mt-4 h-1 bg-[var(--color-dark)]/5\" data-kid=\"192\">\n                                <div class=\"h-full bg-[var(--color-blue)] w-[60%]\" data-kid=\"193\"></div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-12 pt-8 hairline-t flex justify-between items-center\" data-kid=\"194\">\n                        <p class=\"text-[9px] font-bold uppercase tracking-widest opacity-60\" data-kid=\"195\">Real-time sensor feed: Active</p>\n                        <span class=\"text-[9px] font-mono text-[var(--color-blue)]\" data-kid=\"196\">STREAMING...</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-6 row-span-3 hairline-border p-8 bg-white stagger-card\" data-kid=\"197\">\n                    <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"198\">Velocity Log (Alpine Sector)</span>\n                    <div class=\"mt-8 space-y-4\" data-kid=\"199\">\n                        <div class=\"flex items-center justify-between font-mono text-xs hairline-b pb-3\" data-kid=\"200\">\n                            <span class=\"opacity-40 w-16\" data-kid=\"201\">14:00</span>\n                            <div class=\"h-4 w-px bg-[var(--color-dark)]/10\" data-kid=\"202\"></div>\n                            <span class=\"font-bold flex-1 px-4\" data-kid=\"203\">12 km/h</span>\n                            <div class=\"flex items-center gap-2\" data-kid=\"204\">\n                                <span class=\"text-[10px] font-bold\" data-kid=\"205\">NW</span>\n                                <i class=\"ti ti-arrow-up-right text-[var(--color-blue)]\" data-kid=\"206\"></i>\n                            </div>\n                        </div>\n                        <div class=\"flex items-center justify-between font-mono text-xs hairline-b pb-3\" data-kid=\"207\">\n                            <span class=\"opacity-40\" data-kid=\"208\">14:15</span>\n                            <span class=\"font-bold\" data-kid=\"209\">18 km/h</span>\n                            <div class=\"flex items-center gap-2\" data-kid=\"210\">\n                                <span class=\"text-[10px] font-bold\" data-kid=\"211\">W</span>\n                                <i class=\"ti ti-arrow-right text-[var(--color-blue)]\" data-kid=\"212\"></i>\n                            </div>\n                        </div>\n                        <div class=\"flex items-center justify-between font-mono text-xs hairline-b pb-3 text-red-600\" data-kid=\"213\">\n                            <span class=\"opacity-40 w-16\" data-kid=\"214\">14:30</span>\n                            <div class=\"h-4 w-px bg-red-600/20\" data-kid=\"215\"></div>\n                            <span class=\"font-bold flex-1 px-4\" data-kid=\"216\">42 km/h</span>\n                            <div class=\"flex items-center gap-2\" data-kid=\"217\">\n                                <span class=\"text-[10px] font-bold\" data-kid=\"218\">SW</span>\n                                <i class=\"ti ti-arrow-down-right\" data-kid=\"219\"></i>\n                            </div>\n                        </div>\n                        <div class=\"flex items-center justify-between font-mono text-xs hairline-b pb-3\" data-kid=\"220\">\n                            <span class=\"opacity-40\" data-kid=\"221\">14:45</span>\n                            <span class=\"font-bold\" data-kid=\"222\">14 km/h</span>\n                            <div class=\"flex items-center gap-2\" data-kid=\"223\">\n                                <span class=\"text-[10px] font-bold\" data-kid=\"224\">NW</span>\n                                <i class=\"ti ti-arrow-up-right text-[var(--color-blue)]\" data-kid=\"225\"></i>\n                            </div>\n                        </div>\n                        <div class=\"flex items-center justify-between font-mono text-xs hairline-b pb-3\" data-kid=\"226\">\n                            <span class=\"opacity-40\" data-kid=\"227\">15:00</span>\n                            <span class=\"font-bold\" data-kid=\"228\">09 km/h</span>\n                            <div class=\"flex items-center gap-2\" data-kid=\"229\">\n                                <span class=\"text-[10px] font-bold\" data-kid=\"230\">N</span>\n                                <i class=\"ti ti-arrow-up text-[var(--color-blue)]\" data-kid=\"231\"></i>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-8 flex justify-between items-center\" data-kid=\"232\">\n                        <span class=\"text-[9px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"233\">Total readings: 1,440/day</span>\n                        <a href=\"#\" class=\"text-[9px] font-bold uppercase tracking-widest text-[var(--color-blue)] underline\" data-kid=\"234\">Full log</a>\n                    </div>\n                </div>\n            </div>\n\n            \n            <footer class=\"mt-24 pt-12 hairline-t flex justify-between items-start mb-12\" data-kid=\"235\">\n                <div class=\"max-w-xs\" data-kid=\"236\">\n                    <p class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 mb-4\" data-kid=\"237\">Metadata Protocol</p>\n                    <p class=\"text-[10px] leading-relaxed opacity-60\" data-kid=\"238\">\n                        All data provided by the Swiss Federal Office of Meteorology and Climatology (MeteoSwiss). Data sets are refreshed every 60 seconds unless otherwise specified.\n                    </p>\n                </div>\n                <div class=\"text-right\" data-kid=\"239\">\n                    <p class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 mb-4\" data-kid=\"240\">Certifications</p>\n                    <div class=\"flex gap-4 justify-end\" data-kid=\"241\">\n                        <div class=\"w-8 h-8 hairline-border flex items-center justify-center font-mono text-[8px] font-bold\