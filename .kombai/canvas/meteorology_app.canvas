      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Roboto+Mono:wght@400;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --bg-main: #F7F7F7;\n        --text-primary: #2A3439;\n        --accent-blue: #0070FF;\n        --grid-line: #2A3439;\n    }\n\n    .swiss-grid-bg {\n        background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);\n        background-size: 20px 20px;\n        background-color: var(--bg-main);\n    }\n\n    .font-mono {\n        font-family: 'Roboto Mono', monospace;\n    }\n\n    .font-sans {\n        font-family: 'Inter', sans-serif;\n    }\n\n    /* GSAP specific: Initial states for animation */\n    .log-row {\n        opacity: 0;\n        transform: translateY(12px);\n    }\n\n    .status-dot {\n        width: 6px;\n        height: 6px;\n        background-color: var(--accent-blue);\n        display: block;\n    }\n\n    .hairline {\n        border-width: 1px;\n        border-color: var(--text-primary);\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar {\n        width: 3px;\n    }\n    ::-webkit-scrollbar-track {\n        background: var(--bg-main);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--text-primary);\n    }\n</style>\n\n<div class=\"flex min-h-screen bg-[#F7F7F7] text-[#2A3439] font-sans overflow-x-hidden\" data-kid=\"1\">\n    \n    <aside class=\"w-[300px] fixed h-full bg-white border-r border-[#2A3439] flex flex-col z-50\" data-kid=\"2\">\n        <div class=\"p-10 border-b border-[#2A3439] relative overflow-hidden group\" data-kid=\"3\">\n            <div class=\"relative z-10\" data-kid=\"4\">\n                <h1 class=\"text-3xl font-black tracking-tighter leading-none flex items-center gap-2 mb-1\" data-kid=\"5\">\n                    <span class=\"inline-block w-4 h-4 bg-[#0070FF]\" data-kid=\"6\"></span>\n                    STRATO\n                </h1>\n                <p class=\"text-[9px] tracking-[0.3em] font-bold text-[#2A3439]/50 uppercase\" data-kid=\"7\">Precision Meteorology</p>\n            </div>\n            \n            <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none swiss-grid-bg\" data-kid=\"8\"></div>\n        </div>\n\n        <nav class=\"flex-1 py-10\" data-kid=\"9\">\n            <div class=\"px-10 py-3 text-[10px] font-black text-[#2A3439]/30 uppercase tracking-[0.2em] mb-4\" data-kid=\"10\">Main Terminal</div>\n            <ul class=\"space-y-0 text-xs font-bold uppercase tracking-widest\" data-kid=\"11\">\n                <li data-kid=\"12\">\n                    <a href=\"#\" class=\"flex items-center justify-between px-10 py-5 hover:bg-[#F7F7F7] transition-all group\" data-kid=\"13\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"14\">\n                            <span class=\"w-6 h-6 flex items-center justify-center border border-[#2A3439]/20 text-[9px] group-hover:bg-[#2A3439] group-hover:text-white transition-all\" data-kid=\"15\">01</span>\n                            Dashboard\n                        </div>\n                        <i class=\"ti ti-chevron-right text-[10px] opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"16\"></i>\n                    </a>\n                </li>\n                <li class=\"bg-[#2A3439] text-white\" data-kid=\"17\">\n                    <a href=\"#\" class=\"flex items-center justify-between px-10 py-5\" data-kid=\"18\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"19\">\n                            <span class=\"w-6 h-6 flex items-center justify-center border border-white/30 text-[9px]\" data-kid=\"20\">02</span>\n                            Registration Logs\n                        </div>\n                        <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"21\"></i>\n                    </a>\n                </li>\n                <li data-kid=\"22\">\n                    <a href=\"#\" class=\"flex items-center justify-between px-10 py-5 hover:bg-[#F7F7F7] transition-all group\" data-kid=\"23\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"24\">\n                            <span class=\"w-6 h-6 flex items-center justify-center border border-[#2A3439]/20 text-[9px] group-hover:bg-[#2A3439] group-hover:text-white transition-all\" data-kid=\"25\">03</span>\n                            System Reports\n                        </div>\n                        <i class=\"ti ti-chevron-right text-[10px] opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"26\"></i>\n                    </a>\n                </li>\n            </ul>\n        </nav>\n\n        <div class=\"p-10 border-t border-[#2A3439]\" data-kid=\"27\">\n            <div class=\"flex items-center gap-4 mb-8\" data-kid=\"28\">\n                <div class=\"relative\" data-kid=\"29\">\n                    <img src=\"https://i.pravatar.cc/100?u=admin\" alt=\"User\" class=\"w-12 h-12 border border-[#2A3439] grayscale object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"30\">\n                    <div class=\"absolute -bottom-1 -right-1 w-3 h-3 bg-[#0070FF] border-2 border-white\" data-kid=\"31\"></div>\n                </div>\n                <div data-kid=\"32\">\n                    <p class=\"text-xs font-black uppercase tracking-tight leading-none mb-1\" data-kid=\"33\">K. Schneider</p>\n                    <p class=\"text-[9px] text-[#2A3439]/50 font-mono tracking-tighter\" data-kid=\"34\">STA_ALPHA_7_ADMIN</p>\n                </div>\n            </div>\n            \n            <div class=\"relative h-[160px] overflow-hidden border border-[#2A3439]\" data-kid=\"35\">\n                <img id=\"sidebar-cloud-img\" src=\"https://images.unsplash.com/photo-1503198515498-d0bd9ed16902?auto=format&w=600&q=80&fit=crop\" alt=\"Clouds\" class=\"w-full h-full object-cover grayscale opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"36\">\n                <div class=\"absolute inset-0 p-4 flex flex-col justify-between bg-gradient-to-t from-white/90 via-transparent to-transparent\" data-kid=\"37\">\n                    <div class=\"flex justify-end\" data-kid=\"38\">\n                        <span class=\"bg-[#2A3439] text-white text-[8px] font-bold px-1.5 py-0.5 tracking-widest uppercase\" data-kid=\"39\">Live Cam</span>\n                    </div>\n                    <div class=\"flex flex-col gap-0.5\" data-kid=\"40\">\n                        <span class=\"text-[9px] font-black uppercase tracking-widest leading-none\" data-kid=\"41\">High Altitude Feed</span>\n                        <span class=\"text-[8px] font-mono text-[#2A3439]/60\" data-kid=\"42\">46.8182° N, 8.2275° E</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"ml-[300px] flex-1 min-w-0\" data-kid=\"43\">\n        \n        <header class=\"h-24 bg-white border-b border-[#2A3439] flex items-center justify-between px-16 sticky top-0 z-40\" data-kid=\"44\">\n            <div class=\"flex items-center gap-10\" data-kid=\"45\">\n                <div class=\"flex items-center gap-4 text-[11px] font-black tracking-[0.2em] uppercase text-[#2A3439]/40\" data-kid=\"46\">\n                    <i class=\"ti ti-map-pin text-[14px]\" data-kid=\"47\"></i>\n                    <span class=\"tracking-[0.3em]\" data-kid=\"48\">Station Alpha-7</span>\n                    <span class=\"w-1.5 h-1.5 bg-[#0070FF]\" data-kid=\"49\"></span>\n                    <span class=\"text-[#2A3439]\" data-kid=\"50\">System Logs</span>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-10\" data-kid=\"51\">\n                <div class=\"hidden xl:flex items-center gap-5 text-[10px] font-black tracking-widest uppercase\" data-kid=\"52\">\n                    <div class=\"flex flex-col items-end\" data-kid=\"53\">\n                        <span class=\"text-[#2A3439]/40 leading-none mb-1\" data-kid=\"54\">Uptime</span>\n                        <span class=\"font-mono text-[12px]\" data-kid=\"55\">99.98%</span>\n                    </div>\n                    <div class=\"w-px h-6 bg-[#2A3439]/10\" data-kid=\"56\"></div>\n                    <div class=\"flex flex-col items-end\" data-kid=\"57\">\n                        <span class=\"text-[#2A3439]/40 leading-none mb-1\" data-kid=\"58\">Sync</span>\n                        <span class=\"flex items-center gap-2 text-[#0070FF] font-mono text-[12px]\" data-kid=\"59\">\n                            <span class=\"w-1.5 h-1.5 bg-[#0070FF] animate-pulse\" data-kid=\"60\"></span>\n                            Active\n                        </span>\n                    </div>\n                </div>\n                <button class=\"bg-[#0070FF] text-white text-[11px] font-black uppercase tracking-[0.3em] px-8 py-3.5 hover:bg-[#003da1] transition-all relative overflow-hidden group\" data-kid=\"61\">\n                    <span class=\"relative z-10\" data-kid=\"62\">New Entry Record</span>\n                    <div class=\"absolute inset-0 bg-white/10 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-300\" data-kid=\"63\"></div>\n                </button>\n            </div>\n        </header>\n\n        <div class=\"p-16 max-w-7xl mx-auto\" data-kid=\"64\">\n            \n            <div class=\"mb-16\" data-kid=\"65\">\n                <div class=\"flex flex-col lg:flex-row justify-between items-start mb-10 gap-10\" data-kid=\"66\">\n                    <div class=\"flex-1\" data-kid=\"67\">\n                        <div class=\"flex items-center gap-4 mb-8\" data-kid=\"68\">\n                            <span class=\"bg-[#2A3439] text-white text-[9px] font-black px-2 py-0.5 tracking-widest uppercase\" data-kid=\"69\">Dataset v4.2</span>\n                            <span class=\"text-[9px] font-bold tracking-[0.3em] uppercase text-[#2A3439]/40\" data-kid=\"70\">Verified Registry</span>\n                        </div>\n                        <h2 class=\"text-6xl md:text-[80px] xl:text-[100px] font-black tracking-[-0.06em] uppercase leading-[0.8] mb-8\" data-kid=\"71\">\n                            Temperature<br data-kid=\"72\">Registers\n                        </h2>\n                    </div>\n                    <div class=\"flex flex-row lg:flex-col gap-10 lg:gap-6 text-right lg:mt-12 shrink-0\" data-kid=\"73\">\n                        <div class=\"border-b border-[#2A3439] pb-4\" data-kid=\"74\">\n                            <p class=\"text-[10px] font-black uppercase tracking-widest text-[#2A3439]/40 mb-1\" data-kid=\"75\">Archived Records</p>\n                            <p class=\"text-4xl xl:text-5xl font-mono font-bold leading-none tracking-tighter\" data-kid=\"76\">14,802</p>\n                        </div>\n                        <div data-kid=\"77\">\n                            <p class=\"text-[10px] font-black uppercase tracking-widest text-[#2A3439]/40 mb-1\" data-kid=\"78\">UTC Reference</p>\n                            <p class=\"text-4xl xl:text-5xl font-mono font-bold leading-none tracking-tighter\" data-kid=\"79\">14:05:22</p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"h-px bg-[#2A3439] w-full\" data-kid=\"80\"></div>\n                <p class=\"mt-8 text-lg max-w-2xl leading-[1.6] text-[#2A3439]/80 font-medium\" data-kid=\"81\">\n                    Continuous atmospheric monitoring from Station Alpha-7. The following data points represent validated telemetry from the primary sensory array.\n                </p>\n            </div>\n\n            \n            <div class=\"grid grid-cols-12 mb-10 border border-[#2A3439] bg-white\" data-kid=\"82\">\n                <div class=\"col-span-6 p-6 border-r border-[#2A3439] flex items-center gap-5\" data-kid=\"83\">\n                    <i class=\"ti ti-search text-[#2A3439]/30 text-xl\" data-kid=\"84\"></i>\n                    <input type=\"text\" placeholder=\"FILTER BY TIMESTAMP, SENSOR ID, OR VALUE...\" class=\"bg-transparent border-none outline-hidden text-[12px] font-black tracking-[0.2em] uppercase w-full placeholder:text-[#2A3439]/20\" data-kid=\"85\">\n                </div>\n                <div class=\"col-span-3 p-6 border-r border-[#2A3439] flex items-center justify-between cursor-pointer hover:bg-[#F7F7F7] transition-all group\" data-kid=\"86\">\n                    <div class=\"flex flex-col\" data-kid=\"87\">\n                        <span class=\"text-[9px] font-bold tracking-widest uppercase text-[#2A3439]/40 mb-1\" data-kid=\"88\">Date Range</span>\n                        <span class=\"text-[11px] font-black tracking-widest uppercase\" data-kid=\"89\">Last 24 Hours</span>\n                    </div>\n                    <i class=\"ti ti-calendar text-[#2A3439]/40 text-lg\" data-kid=\"90\"></i>\n                </div>\n                <div class=\"col-span-3 p-6 flex items-center justify-between cursor-pointer bg-[#2A3439] text-white hover:bg-[#1a2125] transition-all\" data-kid=\"91\">\n                    <span class=\"text-[11px] font-black tracking-widest uppercase\" data-kid=\"92\">Download PDF/CSV</span>\n                    <i class=\"ti ti-file-download text-lg\" data-kid=\"93\"></i>\n                </div>\n            </div>\n\n            \n            <div class=\"bg-white border border-[#2A3439] relative\" data-kid=\"94\">\n                \n                <div class=\"grid grid-cols-[60px_1.2fr_1fr_1.5fr_1.2fr_1.2fr] bg-[#2A3439] text-white px-8 py-5 text-[10px] font-black uppercase tracking-[0.25em] items-center\" data-kid=\"95\">\n                    <div class=\"opacity-40\" data-kid=\"96\">STAT</div>\n                    <div data-kid=\"97\">Date Index</div>\n                    <div data-kid=\"98\">Time (UTC)</div>\n                    <div data-kid=\"99\">Temperature (Sensors 1-3)</div>\n                    <div data-kid=\"100\">Humidity Index</div>\n                    <div data-kid=\"101\">Barometric Pressure</div>\n                </div>\n\n                \n                <div id=\"log-grid-container\" class=\"divide-y divide-[#2A3439]\" data-kid=\"102\">\n                    \n                    \n                    <div class=\"log-row grid grid-cols-[60px_1.2fr_1fr_1.5fr_1.2fr_1.2fr] px-8 py-6 hover:bg-[#0070FF]/5 transition-colors items-center font-mono group\" data-kid=\"103\">\n                        <div class=\"flex items-center\" data-kid=\"104\">\n                            <span class=\"status-dot\" data-kid=\"105\"></span>\n                        </div>\n                        <div class=\"text-[14px] text-[#2A3439]/50 tracking-tighter\" data-kid=\"106\">2024.05.24</div>\n                        <div class=\"text-[14px] font-bold tracking-tighter\" data-kid=\"107\">14:05:22</div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"108\">\n                            <span class=\"text-2xl font-black text-[#0070FF] tracking-tighter\" data-kid=\"109\">22.42</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"110\">DEG_CELSIUS</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"111\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"112\">48.5</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"113\">%_RH</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"114\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"115\">1013.2</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"116\">HPA</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"log-row grid grid-cols-[60px_1.2fr_1fr_1.5fr_1.2fr_1.2fr] px-8 py-6 hover:bg-[#0070FF]/5 transition-colors items-center font-mono group bg-[#F7F7F7]/40\" data-kid=\"117\">\n                        <div class=\"flex items-center\" data-kid=\"118\">\n                            <span class=\"status-dot\" data-kid=\"119\"></span>\n                        </div>\n                        <div class=\"text-[14px] text-[#2A3439]/50 tracking-tighter\" data-kid=\"120\">2024.05.24</div>\n                        <div class=\"text-[14px] font-bold tracking-tighter\" data-kid=\"121\">14:00:15</div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"122\">\n                            <span class=\"text-2xl font-black text-[#0070FF] tracking-tighter\" data-kid=\"123\">22.18</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"124\">DEG_CELSIUS</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"125\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"126\">49.0</span>\n                            <span class=\"text-[10px] font-sans font-black text-[#2A3439]/30 uppercase tracking-[0.2em]\" data-kid=\"127\">%_RH</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"128\">\n                            <span class=\"text-[16px] font-bold tracking-tighter\" data-kid=\"129\">1012.8</span>\n                            <span class=\"text-[10px] font-sans font-blac