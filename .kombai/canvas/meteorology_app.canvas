      "html": "\n<body class=\"bg-[#010B13] text-[#f0f0f0] font-['IBM_Plex_Sans',sans-serif] selection:bg-[#39FF14] selection:text-[#010B13] overflow-hidden\">\n  <style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap');\n    \n    :root {\n      --ink-black: #010B13;\n      --pine-teal: #2A705B; /* Brightened slightly for better contrast */\n      --pine-teal-dark: #1B4D3E;\n      --laser-green: #39FF14;\n      --laser-green-glow: rgba(57, 255, 20, 0.4);\n    }\n\n    .font-heading { font-family: 'Space Grotesk', sans-serif; }\n    .font-mono { font-family: 'IBM Plex Mono', monospace; }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar { width: 4px; }\n    ::-webkit-scrollbar-track { background: var(--ink-black); }\n    ::-webkit-scrollbar-thumb { background: var(--pine-teal); }\n    ::-webkit-scrollbar-thumb:hover { background: var(--laser-green); }\n\n    /* Neon Inset Pattern */\n    .neon-inset {\n      border: 1.5px solid var(--laser-green);\n      background: rgba(1, 11, 19, 0.8);\n      box-shadow: 0 0 15px rgba(57, 255, 20, 0.15), inset 0 0 20px rgba(57, 255, 20, 0.05);\n    }\n\n    /* Glitch Effect */\n    .glitch-card {\n      position: relative;\n      /* Removed transition-all to prevent GSAP conflicts */\n    }\n    .glitch-card::before, .glitch-card::after {\n      content: '';\n      position: absolute;\n      top: 0; left: 0; right: 0; bottom: 0;\n      border: 1px solid transparent;\n      z-index: -1;\n      opacity: 0;\n      transition: all 0.2s ease;\n    }\n    .glitch-card:hover::before {\n      opacity: 0.6;\n      border-color: #39FF14;\n      transform: translate(-2px, 1px);\n      animation: glitch-anim-1 0.2s infinite;\n    }\n    .glitch-card:hover::after {\n      opacity: 0.6;\n      border-color: #2A705B;\n      transform: translate(2px, -1px);\n      animation: glitch-anim-2 0.2s infinite;\n    }\n\n    @keyframes glitch-anim-1 {\n      0% { transform: translate(-2px, 2px); }\n      50% { transform: translate(-4px, -1px); }\n      100% { transform: translate(-2px, 2px); }\n    }\n    @keyframes glitch-anim-2 {\n      0% { transform: translate(2px, -2px); }\n      50% { transform: translate(4px, 1px); }\n      100% { transform: translate(2px, -2px); }\n    }\n\n    /* Scanline effect */\n    .scanline {\n      width: 100%;\n      height: 150px;\n      z-index: 50;\n      background: linear-gradient(0deg, rgba(57, 255, 20, 0) 0%, rgba(57, 255, 20, 0.03) 50%, rgba(57, 255, 20, 0) 100%);\n      opacity: 0.2;\n      position: absolute;\n      bottom: 100%;\n      animation: scanline 12s linear infinite;\n      pointer-events: none;\n    }\n    @keyframes scanline {\n      0% { bottom: 100%; }\n      100% { bottom: -100px; }\n    }\n\n    /* Crosshair */\n    .crosshair-bg {\n      background-image: \n        radial-gradient(circle at 2px 2px, var(--pine-teal) 1px, transparent 0);\n      background-size: 40px 40px;\n    }\n\n    .shimmer-green {\n      background: linear-gradient(90deg, transparent, rgba(57, 255, 20, 0.1), transparent);\n      background-size: 200% 100%;\n      animation: shimmer 2s infinite;\n    }\n    @keyframes shimmer {\n      0% { background-position: -200% 0; }\n      100% { background-position: 200% 0; }\n    }\n  </style>\n\n  \n  <div class=\"fixed inset-0 z-0 opacity-15 pointer-events-none crosshair-bg\" data-kid=\"1\"></div>\n  <div class=\"fixed inset-0 z-0 opacity-10 pointer-events-none\" data-kid=\"2\">\n    <img src=\"https://images.unsplash.com/photo-1774646598667-1c40a1011168?auto=format&w=1920&q=80&fit=crop\" alt=\"Topography\" class=\"w-full h-full object-cover mix-blend-screen\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n  </div>\n  <div class=\"scanline\" data-kid=\"4\"></div>\n\n  \n  <div class=\"relative z-10 flex h-screen w-full overflow-hidden border border-[var(--pine-teal)]/30\" data-kid=\"5\">\n    \n    \n    <aside class=\"w-20 flex flex-col items-center py-8 bg-[var(--ink-black)] border-r border-[var(--pine-teal)]/40 shrink-0\" data-kid=\"6\">\n      <div class=\"relative group cursor-pointer mb-12\" data-kid=\"7\">\n        <div class=\"w-12 h-12 bg-[var(--laser-green)] flex items-center justify-center rounded-sm shadow-[0_0_20px_var(--laser-green-glow)]\" data-kid=\"8\">\n          <i class=\"ti ti-radar-2 text-[var(--ink-black)] text-2xl\" data-kid=\"9\"></i>\n        </div>\n        <div class=\"absolute -inset-1 border border-[var(--laser-green)]/30 rounded-sm scale-110 group-hover:scale-125 transition-transform\" data-kid=\"10\"></div>\n      </div>\n\n      <nav class=\"flex flex-col gap-10\" data-kid=\"11\">\n        <div class=\"group relative flex items-center justify-center\" data-kid=\"12\">\n          <i class=\"ti ti-layout-dashboard text-[var(--pine-teal)] text-2xl cursor-pointer hover:text-[var(--laser-green)] transition-colors\" data-kid=\"13\"></i>\n          <span class=\"absolute left-16 bg-[var(--pine-teal)] text-[var(--laser-green)] px-2 py-1 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"14\">DASHBOARD</span>\n        </div>\n        <div class=\"group relative flex items-center justify-center\" data-kid=\"15\">\n          <i class=\"ti ti-file-analytics text-[var(--laser-green)] text-2xl cursor-pointer\" data-kid=\"16\"></i>\n          <div class=\"absolute -right-[1.5px] w-1 h-8 bg-[var(--laser-green)] shadow-[0_0_15px_var(--laser-green)] rounded-l-full\" data-kid=\"17\"></div>\n          <span class=\"absolute left-16 bg-[var(--pine-teal-dark)] border border-[var(--laser-green)]/30 text-[var(--laser-green)] px-3 py-1.5 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"18\">RELATÓRIOS</span>\n        </div>\n        <div class=\"group relative flex items-center justify-center\" data-kid=\"19\">\n          <i class=\"ti ti-chart-dots text-[var(--pine-teal)] text-2xl cursor-pointer hover:text-[var(--laser-green)] transition-colors\" data-kid=\"20\"></i>\n          <span class=\"absolute left-16 bg-[var(--pine-teal)] text-[var(--laser-green)] px-2 py-1 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"21\">HISTÓRICO</span>\n        </div>\n        <div class=\"group relative flex items-center justify-center\" data-kid=\"22\">\n          <i class=\"ti ti-broadcast text-[var(--pine-teal)] text-2xl cursor-pointer hover:text-[var(--laser-green)] transition-colors\" data-kid=\"23\"></i>\n          <span class=\"absolute left-16 bg-[var(--pine-teal)] text-[var(--laser-green)] px-2 py-1 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"24\">SENSORES</span>\n        </div>\n      </nav>\n\n      <div class=\"mt-auto\" data-kid=\"25\">\n        <i class=\"ti ti-settings text-[var(--pine-teal)]/50 text-2xl cursor-pointer hover:text-[var(--laser-green)] transition-colors\" data-kid=\"26\"></i>\n      </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col overflow-hidden bg-[var(--ink-black)]/40 backdrop-blur-sm\" data-kid=\"27\">\n      \n      \n      <header class=\"h-24 border-b border-[var(--pine-teal)]/30 flex items-center justify-between px-10 shrink-0\" data-kid=\"28\">\n        <div class=\"flex items-center gap-6\" data-kid=\"29\">\n          <div class=\"flex flex-col\" data-kid=\"30\">\n            <div class=\"flex items-center gap-3 mb-1\" data-kid=\"31\">\n              <span class=\"w-2.5 h-2.5 rounded-full bg-[var(--laser-green)] animate-pulse shadow-[0_0_10px_var(--laser-green)]\" data-kid=\"32\"></span>\n              <h1 class=\"font-heading text-2xl font-bold tracking-tight uppercase text-[var(--laser-green)] whitespace-nowrap\" data-kid=\"33\">Radar Técnico <span class=\"text-white/20 mx-1 font-light\" data-kid=\"34\">|</span> <span class=\"text-white/80\" data-kid=\"35\">Relatórios</span></h1>\n            </div>\n            <div class=\"flex items-center gap-4 font-mono text-[9px] text-[var(--pine-teal)] uppercase tracking-widest\" data-kid=\"36\">\n              <span class=\"bg-[var(--pine-teal)]/10 px-2 py-0.5 border border-[var(--pine-teal)]/20 font-bold\" data-kid=\"37\">STATION: SP-DOPP-03</span>\n              <span class=\"flex items-center gap-1 font-bold\" data-kid=\"38\"><i class=\"ti ti-activity-heartbeat text-[var(--laser-green)]\" data-kid=\"39\"></i> UPTIME: 99.8%</span>\n              <span id=\"live-clock\" class=\"text-[var(--laser-green)] bg-[var(--laser-green)]/10 px-2 py-0.5 rounded-xs font-bold\" data-kid=\"40\">12:00:00 UTC</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"flex items-center gap-5\" data-kid=\"41\">\n          <div class=\"px-4 py-2 bg-[var(--pine-teal-dark)]/20 border border-[var(--pine-teal)]/30 rounded-xs flex items-center gap-3 focus-within:border-[var(--laser-green)]/50 transition-colors\" data-kid=\"42\">\n            <span class=\"font-mono text-[9px] text-[var(--pine-teal)] font-bold uppercase opacity-60\" data-kid=\"43\">SEARCH_CMD:</span>\n            <input type=\"text\" placeholder=\"CMD_INPUT...\" class=\"bg-transparent border-none outline-hidden font-mono text-xs text-[var(--laser-green)] w-40 placeholder:text-[var(--pine-teal)]/30\" data-kid=\"44\">\n            <i class=\"ti ti-search text-[var(--pine-teal)] text-sm\" data-kid=\"45\"></i>\n          </div>\n          <button class=\"px-4 py-2 border border-[var(--laser-green)] text-[var(--laser-green)] font-heading font-bold text-[10px] uppercase tracking-widest hover:bg-[var(--laser-green)] hover:text-[var(--ink-black)] active:scale-95 transition-all duration-300 cursor-pointer\" data-kid=\"46\">\n            DOWNLOAD_DATA_BATCH\n          </button>\n        </div>\n      </header>\n\n      \n      <div class=\"flex-1 overflow-y-auto p-10\" data-kid=\"47\">\n        \n        \n        <div class=\"flex items-center gap-2 mb-10 overflow-x-auto pb-2 scrollbar-none\" data-kid=\"48\">\n          <button class=\"filter-tab active px-8 py-3 bg-[var(--laser-green)] text-[var(--ink-black)] font-heading font-black uppercase text-xs skew-x-[-15deg] transition-all\" data-kid=\"49\">Todos Relatórios</button>\n          <button class=\"filter-tab px-8 py-3 border border-[var(--pine-teal)]/40 text-[var(--pine-teal)] font-heading font-black uppercase text-xs skew-x-[-15deg] hover:border-[var(--laser-green)] hover:text-[var(--laser-green)] transition-all\" data-kid=\"50\">Aviação (AVN)</button>\n          <button class=\"filter-tab px-8 py-3 border border-[var(--pine-teal)]/40 text-[var(--pine-teal)] font-heading font-black uppercase text-xs skew-x-[-15deg] hover:border-[var(--laser-green)] hover:text-[var(--laser-green)] transition-all\" data-kid=\"51\">Marítimo (MRT)</button>\n          <button class=\"filter-tab px-8 py-3 border border-[var(--pine-teal)]/40 text-[var(--pine-teal)] font-heading font-black uppercase text-xs skew-x-[-15deg] hover:border-[var(--laser-green)] hover:text-[var(--laser-green)] transition-all\" data-kid=\"52\">Agrícola (AGR)</button>\n          <button class=\"filter-tab px-8 py-3 border border-[var(--pine-teal)]/40 text-[var(--pine-teal)] font-heading font-black uppercase text-xs skew-x-[-15deg] hover:border-[var(--laser-green)] hover:text-[var(--laser-green)] transition-all\" data-kid=\"53\">Emergência (EMG)</button>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6\" data-kid=\"54\">\n          \n          \n          <div class=\"glitch-card group bg-[var(--pine-teal-dark)]/10 border border-[var(--pine-teal)]/20 p-5 flex flex-col h-80 cursor-pointer hover:border-[var(--laser-green)]/40 transition-colors duration-300\" data-kid=\"55\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"56\">\n              <div class=\"flex flex-col\" data-kid=\"57\">\n                <span class=\"font-mono text-[9px] text-[var(--laser-green)] bg-[var(--laser-green)]/10 px-1.5 py-0.5 self-start border border-[var(--laser-green)]/20 mb-1 font-bold\" data-kid=\"58\">AVN-SIGMET-09</span>\n                <span class=\"font-mono text-[8px] text-[var(--pine-teal)]/70 tracking-widest uppercase\" data-kid=\"59\">ID: 442-33-01</span>\n              </div>\n              <div class=\"w-8 h-8 rounded-xs border border-[var(--pine-teal)]/20 flex items-center justify-center group-hover:border-[var(--laser-green)]/40 group-hover:bg-[var(--laser-green)]/5 transition-all\" data-kid=\"60\">\n                <i class=\"ti ti-plane text-[var(--pine-teal)] group-hover:text-[var(--laser-green)] text-lg\" data-kid=\"61\"></i>\n              </div>\n            </div>\n            \n            <h3 class=\"font-heading text-lg font-bold text-white/90 mb-2 leading-tight uppercase group-hover:text-[var(--laser-green)] transition-colors\" data-kid=\"62\">Cisalhamento de Vento Baixo</h3>\n            <p class=\"font-body text-xs text-[var(--pine-teal)] leading-relaxed flex-1 font-medium brightness-125\" data-kid=\"63\">Relatório técnico detalhando variações bruscas de direção e velocidade do vento em aproximação final (RWY 17L).</p>\n            \n            <div class=\"mt-auto pt-4 border-t border-[var(--pine-teal)]/20 flex items-center justify-between\" data-kid=\"64\">\n              <div class=\"flex flex-col\" data-kid=\"65\">\n                <span class=\"text-[var(--laser-green)] font-mono text-[10px] font-bold\" data-kid=\"66\">INTENSITY: LEVEL 4</span>\n                <span class=\"text-[var(--pine-teal)] font-mono text-[9px]\" data-kid=\"67\">ALT: 1500FT AGL</span>\n              </div>\n              <div class=\"flex items-center gap-1\" data-kid=\"68\">\n                <span class=\"w-1 h-1 bg-[var(--laser-green)] rounded-full animate-ping\" data-kid=\"69\"></span>\n                <span class=\"font-mono text-[10px] text-[var(--laser-green)]\" data-kid=\"70\">LIVE DATA</span>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"glitch-card group bg-[var(--pine-teal-dark)]/10 border border-[var(--pine-teal)]/20 p-5 flex flex-col h-80 cursor-pointer hover:border-[#00d2ff]/40 hover:transition-colors hover:duration-300\" data-kid=\"71\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"72\">\n              <div class=\"flex flex-col\" data-kid=\"73\">\n                <span class=\"font-mono text-[9px] text-[#00d2ff] bg-[#00d2ff]/10 px-1.5 py-0.5 self-start border border-[#00d2ff]/20 mb-1 font-bold\" data-kid=\"74\">MRT-WAVE-42</span>\n                <span class=\"font-mono text-[8px] text-[var(--pine-teal)]/70 tracking-widest uppercase\" data-kid=\"75\">ID: 881-22-09</span>\n              </div>\n              <div class=\"w-8 h-8 rounded-xs border border-[var(--pine-teal)]/20 flex items-center justify-center group-hover:border-[#00d2ff]/40 group-hover:bg-[#00d2ff]/5 transition-all\" data-kid=\"76\">\n                <i class=\"ti ti-ship text-[var(--pine-teal)] group-hover:text-[#00d2ff] text-lg\" data-kid=\"77\"></i>\n              </div>\n            </div>\n            \n            <h3 class=\"font-heading text-lg font-bold text-white/90 mb-2 leading-tight uppercase group-hover:text-[#00d2ff] transition-colors\" data-kid=\"78\">Estado do Mar: Revolto</h3>\n            <p class=\"font-body text-xs text-[var(--pine-teal)] leading-relaxed flex-1 font-medium brightness-125\" data-kid=\"79\">Monitoramento de swell originário de ciclone extratropical no quadrante sudeste. Ondas de até 5.5 metros.</p>\n            \n            <div class=\"mt-auto pt-4 border-t border-[var(--pine-teal)]/20 flex items-center justify-between\" data-kid=\"80\">\n              <div class=\"flex flex-col\" data-kid=\"81\">\n                <span class=\"text-[#00d2ff] font-mono text-[10px] font-bold\" data-kid=\"82\">HEIGHT: 5.5m</span>\n                <span class=\"text-[var(--pine-teal)] font-mono text-[9px]\" data-kid=\"83\">PERIOD: 12.4 SEC</span>\n              </div>\n              <span class=\"font-mono text-[10px] text-[var(--pine-teal)]\" data-kid=\"84\">UPDATED: 2m AGO</span>\n            </div>\n          </div>\n\n          \n          <div class=\"glitch-card group bg-[var(--pine-teal-dark)]/10 border border-[var(--pine-teal)]/20 p-5 flex flex-col h-80 cursor-pointer hover:border-[#eab308]/40 hover:transition-colors hover:duration-300\" data-kid=\"85\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"86\">\n              <div class=\"flex flex-col\" data-kid=\"87\">\n                <span class=\"font-mono text-[9px] text-[#eab308] bg-[#eab308]/10 px-1.5 py-0.5 self-start border border-[#eab308]/20 mb-1 font-bold\" data-kid=\"88\">AGR-FROST-01</span>\n                <span class=\"font-mono text-[8px] text-[var(--pine-teal)]/70 tracking-widest uppercase\" data-kid=\"89\">ID: 112-99-44</span>\n              </div>\n              <div class=\"w-8 h-8 rounded-xs border border-[var(--pine-teal)]/20 flex items-center justify-center group-hover:border-[#eab308]/40 group-hover:bg-[#eab308]/5 transition-all\" data-kid=\"90\">\n                <i class=\"ti ti-leaf text-[var(--pine-teal)] group-hover:text-[#eab308] text-lg\" data-kid=\"91\"></i>\n              </div>\n            </div>\n            \n            <h3 class=\"font-heading text-lg font-bold text-white/90 mb-2 leading-tight uppercase group-hover:text-[#eab308] transition-colors\" data-kid=\"92\">Alerta de Geada Negra</h3>\n            <p class=\"font-body text-xs text-[var(--pine-teal)] leading-relaxed flex-1 font-medium brightness-125\" data-kid=\"93\">Probabilidade crítica de queda brusca de temperatura em regiões de vale. Risco alto para cafezais.</p>\n            \n            <div class=\"mt-auto pt-4 border-t border-[var(--pine-teal)]/20 flex items-center justify-between\" data-kid=\"94\">\n              <div class=\"flex flex-col\" data-kid=\"95\">\n                <span class=\"text-[#eab308] font-mono text-[10px] font-bold\" data-kid=\"96\">TEMP: -1.2°C</span>\n                <span class=\"text-[var(--pine-teal)] font-mono text-[9px]\" data-kid=\"97\">RISK: CRITICAL</span>\n              </div>\n              <span class=\"font-mono text-[10px] text-[var(--pine-teal)]\" data-kid=\"98\">FORECAST: +6H</span>\n            </div>\n          </div>\n\n          \n          <div class=\"glitch-card group bg-[var(--pine-teal-dark)]/10 border border-[var(--pine-teal)]/20 p-5 flex flex-col h-80 cursor-pointer hover:border-[var(--laser-green)]/40 hover:transition-colors hover:duration-300\" data-kid=\"99\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"100\">\n              <div class=\"flex flex-col\" data-kid=\"101\">\n                <span class=\"font-mono text-[9px] text-[var(--laser-green)] bg-[var(--laser-green)]/10 px-1.5 py-0.5 self-start border border-[var(--laser-green)]/20 mb-1 font-bold\" data-kid=\"102\">SYS-RADAR-DOPP</span>\n                <span class=\"font-mono text-[8px] text-[var(--pine-teal)]/70 tracking-widest uppercase\" data-kid=\"103\">SCAN: FULL SECTOR</span>\n              </div>\n              <div class=\"w-8 h-8 rounded-xs border border-[var(--pine-teal)]/20 flex items-center justify-center\" data-kid=\"104\">\n                <i class=\"ti ti-circle-half-vertical text-[var(--laser-green)] animate-spin-slow text-lg\" data-kid=\"105\"></i>\n              </div>\n            </div>\n            \n            <h3 class=\"font-heading text-lg font-bold text-white/90 mb-2 leading-tight uppercase group-hover:text-[var(--laser-green)] transition-colors\" data-kid=\"106\">Varredura de Refletividade</h3>\n            <p class=\"font-body text-xs text-[var(--pine-teal)] leading-relaxed flex-1 font-medium brightness-125\" data-kid=\"107\">Análise volumétrica de precipitaç