      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Roboto+Mono:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Inter', sans-serif;\n    background-color: #F7F7F7;\n    color: #2A3439;\n  }\n\n  .font-mono {\n    font-family: 'Roboto Mono', monospace;\n  }\n\n  /* Custom Scrollbar for Swiss style */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #F7F7F7;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #2A3439;\n  }\n\n  .hairline-border {\n    border: 1px solid #2A3439;\n  }\n\n  .hairline-b { border-bottom: 1px solid #2A3439; }\n  .hairline-r { border-right: 1px solid #2A3439; }\n  .hairline-t { border-top: 1px solid #2A3439; }\n  .hairline-l { border-left: 1px solid #2A3439; }\n\n  .chart-line {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n  }\n</style>\n\n<div class=\"flex h-screen w-full overflow-hidden\" data-kid=\"1\">\n  \n  <aside id=\"sidebar\" class=\"w-64 hairline-r flex flex-col h-full bg-white z-20 shrink-0\" data-kid=\"2\">\n    <div class=\"p-8 hairline-b\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-8 h-8 bg-[#0070FF] flex items-center justify-center text-white\" data-kid=\"5\">\n          <i class=\"ti ti-cloud-sun text-xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-extrabold tracking-tighter text-xl uppercase leading-none\" data-kid=\"7\">Meteo.<br data-kid=\"8\">Swiss</span>\n      </div>\n    </div>\n    \n    <nav class=\"flex-1 p-8 space-y-10 overflow-y-auto\" data-kid=\"9\">\n      <div class=\"space-y-6\" data-kid=\"10\">\n        <p class=\"text-[10px] uppercase tracking-[0.3em] font-black text-[#2A3439]/40\" data-kid=\"11\">Operational</p>\n        <ul class=\"space-y-4\" data-kid=\"12\">\n          <li data-kid=\"13\">\n            <a href=\"#\" class=\"flex items-center gap-4 text-[#0070FF] font-bold group\" data-kid=\"14\">\n              <div class=\"w-1 h-6 bg-[#0070FF] -ml-8 mr-3\" data-kid=\"15\"></div>\n              <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"16\"></i>\n              <span class=\"tracking-tighter\" data-kid=\"17\">DASHBOARD</span>\n            </a>\n          </li>\n          <li data-kid=\"18\">\n            <a href=\"#\" class=\"flex items-center gap-4 text-[#2A3439] hover:text-[#0070FF] transition-colors group\" data-kid=\"19\">\n              <i class=\"ti ti-clipboard-list text-xl\" data-kid=\"20\"></i>\n              <span class=\"py-1\" data-kid=\"21\">Activity Logs</span>\n            </a>\n          </li>\n          <li data-kid=\"22\">\n            <a href=\"#\" class=\"flex items-center gap-4 text-[#2A3439] hover:text-[#0070FF] transition-colors group\" data-kid=\"23\">\n              <i class=\"ti ti-chart-bar text-xl\" data-kid=\"24\"></i>\n              <span class=\"py-1\" data-kid=\"25\">Detailed Reports</span>\n            </a>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"26\">\n        <p class=\"text-[10px] uppercase tracking-[0.3em] font-black text-[#2A3439]/40\" data-kid=\"27\">Scientific</p>\n        <ul class=\"space-y-4\" data-kid=\"28\">\n          <li data-kid=\"29\">\n            <a href=\"#\" class=\"flex items-center gap-4 text-[#2A3439] hover:text-[#0070FF] transition-colors group\" data-kid=\"30\">\n              <i class=\"ti ti-satellite text-xl\" data-kid=\"31\"></i>\n              <span class=\"py-1\" data-kid=\"32\">Satellite Feed</span>\n            </a>\n          </li>\n          <li data-kid=\"33\">\n            <a href=\"#\" class=\"flex items-center gap-4 text-[#2A3439] hover:text-[#0070FF] transition-colors group\" data-kid=\"34\">\n              <i class=\"ti ti-database text-xl\" data-kid=\"35\"></i>\n              <span class=\"py-1\" data-kid=\"36\">Historical Data</span>\n            </a>\n          </li>\n        </ul>\n      </div>\n    </nav>\n\n    <div class=\"p-8 hairline-t bg-[#F7F7F7]\" data-kid=\"37\">\n      <div class=\"flex items-center gap-3\" data-kid=\"38\">\n        <div class=\"w-10 h-10 hairline-border flex items-center justify-center bg-white overflow-hidden\" data-kid=\"39\">\n          <img src=\"https://i.pravatar.cc/100?u=scientist\" alt=\"User\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n        </div>\n        <div class=\"overflow-hidden\" data-kid=\"41\">\n          <p class=\"text-[11px] font-black uppercase tracking-tight truncate\" data-kid=\"42\">Dr. Aris Thorne</p>\n          <p class=\"text-[9px] font-mono text-[#2A3439]/60 uppercase\" data-kid=\"43\">Chief Observer / S-7</p>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col relative overflow-y-auto bg-[#F7F7F7]\" data-kid=\"44\">\n    \n    <header class=\"sticky top-0 h-20 hairline-b bg-white/80 backdrop-blur-md flex items-center justify-between px-10 z-10\" data-kid=\"45\">\n      <div class=\"flex items-center gap-4 text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"46\">\n        <span class=\"text-[#2A3439]/70\" data-kid=\"47\">Station Network</span>\n        <i class=\"ti ti-chevron-right text-[8px] text-[#2A3439]/40\" data-kid=\"48\"></i>\n        <span class=\"text-[#2A3439]\" data-kid=\"49\">Central Station Alpha // Zurich</span>\n      </div>\n      \n      <div class=\"flex items-center gap-8\" data-kid=\"50\">\n        <div class=\"hidden lg:flex flex-col items-end\" data-kid=\"51\">\n           <span class=\"text-[9px] font-black uppercase tracking-widest text-[#2A3439]/60\" data-kid=\"52\">System Synchronization</span>\n           <span class=\"text-[10px] font-mono text-[#0070FF] font-bold\" data-kid=\"53\">100% NOMINAL // LIVE UPDATES</span>\n        </div>\n        <div class=\"flex items-center gap-2\" data-kid=\"54\">\n          <button class=\"w-10 h-10 hairline-border flex items-center justify-center hover:bg-[#2A3439] hover:text-white transition-colors group\" data-kid=\"55\">\n            <i class=\"ti ti-search text-lg\" data-kid=\"56\"></i>\n          </button>\n          <button class=\"w-10 h-10 hairline-border flex items-center justify-center hover:bg-[#2A3439] hover:text-white transition-colors group relative\" data-kid=\"57\">\n            <i class=\"ti ti-bell text-lg\" data-kid=\"58\"></i>\n            <span class=\"absolute top-0 right-0 w-2 h-2 bg-[#0070FF]\" data-kid=\"59\"></span>\n          </button>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"p-10 lg:p-14 space-y-12 max-w-7xl mx-auto w-full\" data-kid=\"60\">\n      \n      \n      <section class=\"flex flex-col md:flex-row md:items-end justify-between gap-8 pt-4\" data-kid=\"61\">\n        <div data-kid=\"62\">\n          <div class=\"flex items-center gap-4 mb-4 stat-reveal\" data-kid=\"63\">\n             <span class=\"px-2 py-0.5 bg-[#2A3439] text-white text-[9px] font-mono\" data-kid=\"64\">STATUS: OPERATIONAL</span>\n             <span class=\"text-[9px] font-mono text-[#2A3439]/70 tracking-widest\" data-kid=\"65\">BUILD 4.10.2 // STABLE</span>\n          </div>\n          <h1 class=\"text-6xl md:text-7xl font-black tracking-tighter uppercase leading-[0.85] stat-reveal\" data-kid=\"66\">Station<br data-kid=\"67\">Dashboard</h1>\n          <p class=\"mt-6 text-[10px] font-mono text-[#2A3439]/80 uppercase tracking-[0.3em] stat-reveal\" data-kid=\"68\">Atmospheric Monitoring System // Sector Zurich-01-Alpha</p>\n        </div>\n        <div class=\"flex flex-wrap gap-px bg-[#2A3439] hairline-border stat-reveal h-fit self-start md:mb-1\" data-kid=\"69\">\n           <div class=\"bg-white px-5 py-2.5 flex flex-col min-w-[100px]\" data-kid=\"70\">\n              <span class=\"text-[8px] font-black uppercase tracking-widest text-[#2A3439]/60\" data-kid=\"71\">Lat.</span>\n              <span class=\"text-xs font-mono font-bold\" data-kid=\"72\">47.3769° N</span>\n           </div>\n           <div class=\"bg-white px-5 py-2.5 flex flex-col min-w-[100px]\" data-kid=\"73\">\n              <span class=\"text-[8px] font-black uppercase tracking-widest text-[#2A3439]/60\" data-kid=\"74\">Long.</span>\n              <span class=\"text-xs font-mono font-bold\" data-kid=\"75\">8.5417° E</span>\n           </div>\n           <div class=\"bg-white px-5 py-2.5 flex flex-col min-w-[100px]\" data-kid=\"76\">\n              <span class=\"text-[8px] font-black uppercase tracking-widest text-[#2A3439]/60\" data-kid=\"77\">Alt.</span>\n              <span class=\"text-xs font-mono font-bold\" data-kid=\"78\">408m MSL</span>\n           </div>\n        </div>\n      </section>\n\n      \n      <section id=\"hero-stat\" class=\"grid grid-cols-12 gap-px bg-[#2A3439] border border-[#2A3439] shadow-sm\" data-kid=\"79\">\n        \n        <div class=\"col-span-12 xl:col-span-8 bg-white p-12 flex flex-col justify-between relative overflow-hidden group\" data-kid=\"80\">\n          <div class=\"flex justify-between items-start relative z-10\" data-kid=\"81\">\n            <div data-kid=\"82\">\n              <p class=\"text-[10px] font-black uppercase tracking-[0.4em] text-[#2A3439]/40 mb-3\" data-kid=\"83\">Thermodynamic State</p>\n              <div class=\"flex items-center gap-2\" data-kid=\"84\">\n                <i class=\"ti ti-map-pin text-[#0070FF] animate-pulse\" data-kid=\"85\"></i>\n                <span class=\"text-sm font-black uppercase tracking-widest\" data-kid=\"86\">Zurich Center Station</span>\n              </div>\n            </div>\n            <div class=\"w-14 h-14 bg-[#0070FF] flex items-center justify-center text-white shrink-0\" data-kid=\"87\">\n              <i class=\"ti ti-thermometer text-3xl\" data-kid=\"88\"></i>\n            </div>\n          </div>\n          \n          <div class=\"mt-16 flex items-baseline gap-2 relative z-10\" data-kid=\"89\">\n            <span class=\"text-[120px] md:text-[180px] leading-[0.85] font-black tracking-tighter\" id=\"current-temp\" data-kid=\"90\">21.4</span>\n            <span class=\"text-5xl md:text-7xl font-light text-[#0070FF] font-['Roboto_Mono'] leading-none\" data-kid=\"91\">°C</span>\n          </div>\n\n          <div class=\"mt-10 pt-10 hairline-t grid grid-cols-3 gap-6 relative z-10\" data-kid=\"92\">\n            <div data-kid=\"93\">\n              <p class=\"text-[9px] font-black uppercase tracking-[0.2em] text-[#2A3439]/70 mb-2\" data-kid=\"94\">Apparent Temp.</p>\n              <p class=\"text-3xl md:text-4xl font-['Roboto_Mono'] font-bold tracking-tighter\" data-kid=\"95\">22.8<span class=\"text-lg ml-1 opacity-40\" data-kid=\"96\">°C</span></p>\n            </div>\n            <div data-kid=\"97\">\n              <p class=\"text-[9px] font-black uppercase tracking-[0.2em] text-[#2A3439]/70 mb-2\" data-kid=\"98\">Rel. Humidity</p>\n              <p class=\"text-3xl md:text-4xl font-['Roboto_Mono'] font-bold tracking-tighter\" data-kid=\"99\">54<span class=\"text-lg ml-1 opacity-40\" data-kid=\"100\">%</span></p>\n            </div>\n            <div class=\"text-right\" data-kid=\"101\">\n              <p class=\"text-[9px] font-black uppercase tracking-[0.2em] text-[#2A3439]/70 mb-2\" data-kid=\"102\">Pressure (MSL)</p>\n              <p class=\"text-3xl md:text-4xl font-['Roboto_Mono'] font-bold tracking-tighter\" data-kid=\"103\">1013<span class=\"text-lg ml-1 opacity-40\" data-kid=\"104\">hPa</span></p>\n            </div>\n          </div>\n          \n          \n          <div class=\"absolute inset-0 pointer-events-none opacity-[0.03]\" style=\"background-image: radial-gradient(#2A3439 1px, transparent 0); background-size: 40px 40px;\" data-kid=\"105\"></div>\n        </div>\n\n        \n        <div class=\"col-span-12 xl:col-span-4 flex flex-col gap-px\" data-kid=\"106\">\n          <div class=\"flex-1 bg-white p-12 flex flex-col justify-between group hover:bg-[#F7F7F7]\" data-kid=\"107\">\n            <div class=\"flex justify-between items-start\" data-kid=\"108\">\n              <p class=\"text-[9px] font-black uppercase tracking-[0.4em] text-[#2A3439]/70\" data-kid=\"109\">Daily Maximum</p>\n              <div class=\"text-[#0070FF] flex items-center gap-1 font-mono text-[9px] font-bold bg-[#0070FF]/5 px-2 py-0.5\" data-kid=\"110\">\n                 <i class=\"ti ti-trending-up\" data-kid=\"111\"></i>\n                 <span data-kid=\"112\">+1.2%</span>\n              </div>\n            </div>\n            <div class=\"mt-6 flex items-baseline gap-3\" data-kid=\"113\">\n              <span class=\"text-8xl font-black tracking-tighter\" data-kid=\"114\">24.8</span>\n              <span class=\"text-2xl font-['Roboto_Mono'] text-[#0070FF]\" data-kid=\"115\">°C</span>\n            </div>\n            <div class=\"mt-8 pt-8 hairline-t flex items-center gap-3 text-[#2A3439]/30 font-mono text-[9px] uppercase font-bold\" data-kid=\"116\">\n              <i class=\"ti ti-clock\" data-kid=\"117\"></i>\n              <span data-kid=\"118\">REC // 14:32:15 UTC</span>\n            </div>\n          </div>\n          \n          <div class=\"flex-1 bg-white p-12 flex flex-col justify-between group hover:bg-[#F7F7F7]\" data-kid=\"119\">\n            <div class=\"flex justify-between items-start\" data-kid=\"120\">\n              <p class=\"text-[9px] font-black uppercase tracking-[0.4em] text-[#2A3439]/70\" data-kid=\"121\">Daily Minimum</p>\n              <div class=\"text-[#2A3439]/40 flex items-center gap-1 font-mono text-[9px] font-bold bg-[#2A3439]/5 px-2 py-0.5\" data-kid=\"122\">\n                 <i class=\"ti ti-trending-down\" data-kid=\"123\"></i>\n                 <span data-kid=\"124\">-0.4%</span>\n              </div>\n            </div>\n            <div class=\"mt-6 flex items-baseline gap-3\" data-kid=\"125\">\n             