 text-[9px] font-black uppercase tracking-widest hover:bg-[#2A3439] hover:text-white transition-colors\" data-kid=\"145\">Export .CSV</button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"h-80 w-full relative group\" data-kid=\"146\">\n           \n           <div class=\"absolute inset-0 flex flex-col justify-between pointer-events-none\" data-kid=\"147\">\n              <div class=\"w-full h-px bg-[#2A3439]/5 flex justify-end px-2 text-[8px] font-mono text-[#2A3439]/20\" data-kid=\"148\">25.0</div>\n              <div class=\"w-full h-px bg-[#2A3439]/5 flex justify-end px-2 text-[8px] font-mono text-[#2A3439]/20\" data-kid=\"149\">22.5</div>\n              <div class=\"w-full h-px bg-[#2A3439]/5 flex justify-end px-2 text-[8px] font-mono text-[#2A3439]/20\" data-kid=\"150\">20.0</div>\n              <div class=\"w-full h-px bg-[#2A3439]/5 flex justify-end px-2 text-[8px] font-mono text-[#2A3439]/20\" data-kid=\"151\">17.5</div>\n              <div class=\"w-full h-px bg-[#2A3439]/5 flex justify-end px-2 text-[8px] font-mono text-[#2A3439]/20\" data-kid=\"152\">15.0</div>\n           </div>\n           \n           \n           <svg class=\"w-full h-full overflow-visible\" viewBox=\"0 0 1000 200\" preserveAspectRatio=\"none\" data-kid=\"153\">\n              <defs data-kid=\"154\">\n                <linearGradient id=\"areaGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" data-kid=\"155\">\n                  <stop offset=\"0%\" stop-color=\"#0070FF\" stop-opacity=\"0.1\" data-kid=\"156\"></stop>\n                  <stop offset=\"100%\" stop-color=\"#0070FF\" stop-opacity=\"0\" data-kid=\"157\"></stop>\n                </linearGradient>\n              </defs>\n              \n              <path class=\"chart-area\" d=\"M0,180 L80,165 L160,175 L240,145 L320,155 L400,115 L480,125 L560,85 L640,95 L720,55 L800,65 L880,25 L960,35 L1000,15 L1000,200 L0,200 Z\" fill=\"url(#areaGradient)\" opacity=\"0\" data-kid=\"158\"></path>\n              \n              <path class=\"chart-line\" d=\"M0,180 L80,165 L160,175 L240,145 L320,155 L400,115 L480,125 L560,85 L640,95 L720,55 L800,65 L880,25 L960,35 L1000,15\" stroke=\"#0070FF\" stroke-width=\"2\" fill=\"none\" data-kid=\"159\"></path>\n              \n              \n              <circle cx=\"0\" cy=\"180\" r=\"4\" fill=\"white\" stroke=\"#0070FF\" stroke-width=\"2\" data-kid=\"160\"></circle>\n              <circle cx=\"320\" cy=\"155\" r=\"4\" fill=\"white\" stroke=\"#0070FF\" stroke-width=\"2\" data-kid=\"161\"></circle>\n              <circle cx=\"720\" cy=\"55\" r=\"4\" fill=\"white\" stroke=\"#0070FF\" stroke-width=\"2\" data-kid=\"162\"></circle>\n              <circle cx=\"1000\" cy=\"15\" r=\"4\" fill=\"#0070FF\" data-kid=\"163\"></circle>\n           </svg>\n\n           \n           <div class=\"mt-8 flex justify-between font-mono text-[10px] text-[#2A3439]/40 font-bold uppercase tracking-tighter\" data-kid=\"164\">\n              <span data-kid=\"165\">00:00:00</span>\n              <span data-kid=\"166\">04:00:00</span>\n              <span data-kid=\"167\">08:00:00</span>\n              <span data-kid=\"168\">12:00:00</span>\n              <span data-kid=\"169\">16:00:00</span>\n              <span data-kid=\"170\">20:00:00</span>\n              <span data-kid=\"171\">23:59:59</span>\n           </div>\n\n           \n           <div class=\"absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"172\">\n              <div class=\"absolute top-0 left-[72%] h-full w-px border-l border-dashed border-[#0070FF] flex items-center justify-center\" data-kid=\"173\">\n                 <div class=\"bg-[#2A3439] text-white p-3 text-[10px] font-mono whitespace-nowrap -mt-64 z-20 hairline-border\" data-kid=\"174\">\n                    <span class=\"block text-[#0070FF] font-black mb-1\" data-kid=\"175\">DATA POINT #1824</span>\n                    <span class=\"block\" data-kid=\"176\">TIME: 17:15:04 UTC</span>\n     