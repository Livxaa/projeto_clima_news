      "html": "\n<main id=\"app-container\" class=\"flex min-h-screen bg-[#F7F7F7] font-sans text-[#2A3439] overflow-hidden opacity-0\" data-kid=\"0\">\n  \n  <section id=\"visual-panel\" class=\"hidden lg:flex lg:w-1/2 relative overflow-hidden border-r border-[#2A3439]\" data-kid=\"1\">\n    <img src=\"https://images.unsplash.com/photo-1503198515498-d0bd9ed16902?auto=format&w=1400&q=80&fit=crop\" alt=\"Dramatic stratocumulus clouds\" class=\"absolute inset-0 w-full h-full object-cover grayscale brightness-[0.85] contrast-[1.15]\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n    \n    \n    <div class=\"absolute inset-0 pointer-events-none\" style=\"background-image: linear-gradient(#2A3439 1px, transparent 1px), linear-gradient(90deg, #2A3439 1px, transparent 1px); background-size: 100px 100px; opacity: 0.15;\" data-kid=\"3\"></div>\n\n    \n    <div class=\"absolute top-10 right-10 text-right mix-blend-difference text-white/80 font-mono text-[10px] tracking-widest uppercase\" data-kid=\"4\">\n        <div data-kid=\"5\">Ref. 409-SW / Variant A</div>\n        <div data-kid=\"6\">Calibration: 0.003ms</div>\n    </div>\n\n    \n    <div id=\"telemetry-info\" class=\"absolute bottom-12 left-12 text-white font-mono text-xs tracking-widest uppercase\" data-kid=\"7\">\n        <div class=\"flex items-center gap-3 mb-3\" data-kid=\"8\">\n            <span id=\"telemetry-dot\" class=\"w-1.5 h-1.5 bg-[#0070FF] block rounded-none\" data-kid=\"9\"></span>\n            <span class=\"opacity-80\" data-kid=\"10\">Link: Active-Secure</span>\n        </div>\n        <div class=\"space-y-1\" data-kid=\"11\">\n            <div class=\"flex items-center gap-4\" data-kid=\"12\">\n                <span class=\"opacity-40\" data-kid=\"13\">LOC:</span>\n                <span data-kid=\"14\">47.37° N / 8.54° E</span>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"15\">\n                <span class=\"opacity-40\" data-kid=\"16\">ALT:</span>\n                <span data-kid=\"17\">408M ASL</span>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <section id=\"form-panel\" class=\"w-full lg:w-1/2 flex flex-col justify-center items-center relative\" data-kid=\"18\">\n    \n    <div class=\"absolute inset-0 pointer-events-none opacity-[0.05]\" style=\"background-image: linear-gradient(#2A3439 1px, transparent 1px), linear-gradient(90deg, #2A3439 1px, transparent 1px); background-size: 80px 80px;\" data-kid=\"19\"></div>\n\n    <div class=\"w-full max-w-md px-10 lg:px-0 relative z-10\" data-kid=\"20\">\n      \n      <header class=\"mb-16\" data-kid=\"21\">\n        <div class=\"flex items-center gap-4 mb-3\" data-kid=\"22\">\n            <div class=\"h-[1px] w-10 bg-[#0070FF]\" data-kid=\"23\"></div>\n            <span class=\"font-mono text-[10px] tracking-[0.4em] uppercase text-[#0070FF] font-bold\" data-kid=\"24\">Terminal Online // V.1.0.4</span>\n        </div>\n        <h1 class=\"text-6xl font-black tracking-tighter leading-[0.9] text-[#2A3439] uppercase\" data-kid=\"25\">\n          Stratosphere<br data-kid=\"26\">\n          <span class=\"text-[#2A3439]\" data-kid=\"27\">Precision</span>\n        </h1>\n        <p class=\"mt-6 text-[#2A3439]/60 font-mono text-[10px] tracking-widest uppercase leading-relaxed max-w-[280px]\" data-kid=\"28\">\n          Authorized Personnel Only. Swiss Federal Meteorological Network Access Protocol.\n        </p>\n      </header>\n\n      \n      <form id=\"login-form\" class=\"space-y-8\" data-kid=\"29\">\n        <div class=\"space-y-1\" data-kid=\"30\">\n          <div class=\"absolute -right-2 top-0 font-mono text-[7px] text-[#2A3439]/20 hidden lg:block\" data-kid=\"31\">REF_SYS_01</div>\n          <div class=\"group relative border-b border-[#2A3439] focus-within:border-[#0070FF] transition-colors duration-300\" data-kid=\"32\">\n            <label for=\"username\" class=\"absolute -top-5 left-0 font-mono text-[9px] uppercase tracking-[0.2em] text-[#2A3439]/60 group-focus-within:text-[#0070FF] transition-colors\" data-kid=\"33\">Operator_ID</label>\n            <div class=\"flex items-center\" data-kid=\"34\">\n                <span class=\"font-mono text-[11px] text-[#2A3439]/60 mr-4\" data-kid=\"35\">SYS:</span>\n                <input type=\"text\" id=\"username\" name=\"username\" placeholder=\"OPERATOR_X1\" required class=\"w-full bg-transparent py-4 font-mono text-sm focus:outline-hidden placeholder:text-[#2A3439]/30\" data-kid=\"36\">\n            </div>\n          </div>\n        </div>\n\n        <div class=\"space-y-1\" data-kid=\"37\">\n          <div class=\"group relative border-b border-[#2A3439] focus-within:border-[#0070FF] transition-colors duration-300\" data-kid=\"38\">\n            <label for=\"password\" class=\"absolute -top-5 left-0 font-mono text-[9px] uppercase tracking-[0.2em] text-[#2A3439]/60 group-focus-within:text-[#0070FF] transition-colors\" data-kid=\"39\">Access_Key</label>\n            <div class=\"flex items-center\" data-kid=\"40\">\n                <span class=\"font-mono text-[11px] text-[#2A3439]/60 mr-4\" data-kid=\"41\">KEY:</span>\n                <input type=\"password\" id=\"password\" name=\"password\" placeholder=\"••••••••••••\" required class=\"w-full bg-transparent py-4 font-mono text-sm focus:outline-hidden placeholder:text-[#2A3439]/30\" data-kid=\"42\">\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-6 pt-4\" data-kid=\"43\">\n          <button type=\"submit\" class=\"relative w-full h-14 bg-[#2A3439] text-white font-mono text-xs tracking-[0.2em] uppercase hover:bg-[#0070FF] flex items-center justify-center gap-4 group cursor-pointer\" data-kid=\"44\">\n            <span data-kid=\"45\">Decrypt & Authenticate</span>\n            <i class=\"ti ti-chevron-right text-lg transition-transform duration-500 group-hover:translate-x-1\" data-kid=\"46\"></i>\n          </button>\n          \n          <div class=\"flex items-center justify-between\" data-kid=\"47\">\n              <a href=\"#\" class=\"font-mono text-[9px] uppercase tracking-widest text-[#2A3439]/40 hover:text-[#0070FF] transition-colors border-b border-transparent hover:border-[#0070FF]\" data-kid=\"48\">Lost Credentials</a>\n              <div class=\"h-[1px] flex-1 mx-6 bg-[#2A3439]/5\" data-kid=\"49\"></div>\n              <a href=\"#\" class=\"font-mono text-[9px] uppercase tracking-widest text-[#2A3439]/40 hover:text-[#0070FF] transition-colors border-b border-transparent hover:border-[#0070FF]\" data-kid=\"50\">New Terminal</a>\n          </div>\n        </div>\n      </form>\n\n      \n      <footer class=\"mt-16 flex items-center justify-between border-t border-[#2A3439]/10 pt-10\" data-kid=\"51\">\n        <div class=\"flex items-center gap-4\" data-kid=\"52\">\n            <div class=\"w-10 h-10 border border-[#2A3439]/20 flex items-center justify-center text-[#2A3439]\" data-kid=\"53\">\n                <i class=\"ti ti-temperature-celsius text-xl\" data-kid=\"54\"></i>\n            </div>\n            <div class=\"font-mono text-[9px] leading-tight text-[#2A3439]/60\" data-kid=\"55\">\n                SWISS PRECISION<br data-kid=\"56\">SYSTEMS &copy; 2024\n            </div>\n        </div>\n        <div id=\"live-clock\" class=\"font-mono text-[10px] tracking-tighter text-[#2A3439]/40\" data-kid=\"57\">\n            09:24:12 UTC\n        </div>\n      </footer>\n    </div>\n  </section>\n</main>\n\n<style data-kid=\"58\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&family=Roboto+Mono:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  /* Swiss Style Reset-ish behaviors inside body */\n  :root {\n    --primary: #2A3439;\n    --bg: #F7F7F7;\n    --accent: #0070FF;\n  }\n\n  body {\n    margin: 0;\n    background-color: var(--bg);\n    color: var(--primary);\n  }\n\n  input:-webkit-autofill,\n  input:-webkit-autofill:hover, \n  input:-webkit-autofill:focus {\n    -webkit-text-fill-color: var(--primary);\n    -webkit-box-shadow: 0 0 0px 1000px transparent inset;\n    transition: background-color 5000s ease-in-out 0s;\n  }\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"59\"></script>\n<script data-kid=\"60\">\n  document.addEventListener('DOMContentLoaded', () => {\n    // Reveal main container\n    gsap.to('#app-container', { opacity: 1, duration: 1, ease: 'power2.out' });\n\n    // Stagger in elements\n    const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.4 } });\n\n    tl.from('#visual-panel img', { scale: 1.05, filter: 'grayscale(1) brightness(0.2)', duration: 2.5 })\n      .from('h1', { x: -30, opacity: 0, stagger: 0.1 }, \"-=2\")\n      .from('header p, header .flex', { y: 10, opacity: 0, stagger: 0.1 }, \"-=1.8\")\n      .from('#login-form .group', { y: 20, opacity: 0, stagger: 0.12 }, \"-=1.6\")\n      .from('#login-form button, #login-form .flex', { y: 10, opacity: 0, stagger: 0.1 }, \"-=1.4\")\n      .from('#telemetry-info div', { opacity: 0, x: -20, stagger: 0.08 }, \"-=1.8\")\n      .from('footer', { opacity: 0, y: 20 }, \"-=1.2\");\n\n    // Live Clock Update\n    function updateClock() {\n      const now = new Date();\n      const h = String(now.getUTCHours()).padStart(2, '0');\n      const m = String(now.getUTCMinutes()).padStart(2, '0');\n      const s = String(now.getUTCSeconds()).padStart(2, '0');\n      const clockElement = document.getElementById('live-clock');\n      if (clockElement) {\n        clockElement.textContent = `${h}:${m}:${s} UTC`;\n      }\n    }\n    setInterval(updateClock, 1000);\n    updateClock();\n\n    // Visual interaction for the telemetry dot\n    gsap.to('#telemetry-dot', {\n        opacity: 0.2,\n        repeat: -1,\n        yoyo: true,\n        duration: 0.8,\n        ease: 'power1.inOut'\n    });\n  });\n</script>\n",
