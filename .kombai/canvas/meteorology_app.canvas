      "html": "\n<body class=\"bg-[#1F305E] text-white font-['Figtree'] overflow-x-hidden selection:bg-[#89CFF0]/30\">\n    <style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Figtree:wght@400;500;600&display=swap');\n\n        :root {\n            --color-primary: #1F305E;\n            --color-secondary: #89CFF0;\n            --color-accent: #FF9966;\n        }\n\n        /* Glassmorphism Classes */\n        .glass-card {\n            background: rgba(255, 255, 255, 0.07);\n            backdrop-filter: blur(28px);\n            -webkit-backdrop-filter: blur(28px);\n            border: 1px solid rgba(255, 255, 255, 0.12);\n            border-radius: 24px;\n            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);\n        }\n\n        /* Background Animations */\n        @keyframes morph {\n            0%, 100% { border-radius: 40% 60% 70% 30% / 40% 40% 60% 50%; }\n            34% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; }\n            67% { border-radius: 100% 60% 60% 100% / 100% 100% 60% 60%; }\n        }\n\n        .blob {\n            position: absolute;\n            filter: blur(100px);\n            z-index: 0;\n            opacity: 0.25;\n            animation: morph 20s infinite linear alternate;\n        }\n\n        /* Scrollbar */\n        ::-webkit-scrollbar {\n            width: 8px;\n        }\n        ::-webkit-scrollbar-track {\n            background: rgba(31, 48, 94, 0.1);\n        }\n        ::-webkit-scrollbar-thumb {\n            background: rgba(137, 207, 240, 0.2);\n            border-radius: 10px;\n        }\n        ::-webkit-scrollbar-thumb:hover {\n            background: rgba(137, 207, 240, 0.4);\n        }\n\n        .timeline-line-glow {\n            box-shadow: 0 0 20px rgba(137, 207, 240, 0.2);\n        }\n        \n        .node-glow-orange { box-shadow: 0 0 20px rgba(255, 153, 102, 0.6), 0 0 40px rgba(255, 153, 102, 0.3); }\n        .node-glow-blue { box-shadow: 0 0 20px rgba(137, 207, 240, 0.6), 0 0 40px rgba(137, 207, 240, 0.3); }\n\n        .noise-overlay {\n            position: fixed;\n            inset: 0;\n            background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n            opacity: 0.02;\n            z-index: 1;\n            pointer-events: none;\n        }\n    </style>\n\n    \n    <div class=\"noise-overlay\" data-kid=\"1\"></div>\n    <div class=\"fixed inset-0 pointer-events-none overflow-hidden z-0\" data-kid=\"2\">\n        \n        <video src=\"https://videos.pexels.com/video-files/35092214/14866544_640_360_25fps.mp4\" poster=\"https://images.pexels.com/videos/35092214/4k-natural-4k-timelapse-at-night-aurora-35092214.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover opacity-20 grayscale-[50%]\" data-kid=\"3\"></video>\n        \n        \n        <div class=\"blob w-[600px] h-[600px] bg-[#89CFF0] -top-48 -left-48\" data-kid=\"4\"></div>\n        <div class=\"blob w-[500px] h-[500px] bg-[#FF9966] top-1/2 -right-24 delay-1000\" data-kid=\"5\"></div>\n        <div class=\"blob w-[400px] h-[400px] bg-[#89CFF0] bottom-0 left-1/4 opacity-15\" data-kid=\"6\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 flex min-h-screen\" data-kid=\"7\">\n        \n        \n        <aside class=\"w-20 lg:w-24 fixed h-screen glass-card rounded-none border-r border-white/10 flex flex-col items-center py-10 gap-10\" data-kid=\"8\">\n            <div class=\"w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center border border-white/20\" data-kid=\"9\">\n                <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/cloud.svg\" class=\"w-8 h-8\" alt=\"Logo\" data-kid=\"10\">\n            </div>\n            \n            <nav class=\"flex flex-col gap-8 flex-1\" data-kid=\"11\">\n                <a href=\"#\" class=\"p-3 rounded-xl bg-white/10 text-white shadow-lg transition-transform hover:scale-110\" data-kid=\"12\"><i class=\"ph ph-layout-fill text-2xl\" data-kid=\"13\"></i></a>\n                <a href=\"#\" class=\"p-3 rounded-xl text-white/70 hover:bg-white/10 hover:text-white transition-all hover:scale-110\" data-kid=\"14\"><i class=\"ph ph-chart-line-up text-2xl\" data-kid=\"15\"></i></a>\n                <a href=\"#\" class=\"p-3 rounded-xl text-white/70 hover:bg-white/10 hover:text-white transition-all hover:scale-110\" data-kid=\"16\"><i class=\"ph ph-calendar-blank text-2xl\" data-kid=\"17\"></i></a>\n                <a href=\"#\" class=\"p-3 rounded-xl text-white/70 hover:bg-white/10 hover:text-white transition-all hover:scale-110\" data-kid=\"18\"><i class=\"ph ph-gear text-2xl\" data-kid=\"19\"></i></a>\n            </nav>\n\n            <div class=\"flex flex-col gap-6 relative\" data-kid=\"20\">\n                 <img src=\"https://i.pravatar.cc/100?u=meteo\" class=\"w-10 h-10 rounded-full border border-white/20\" alt=\"Avatar\" data-kid=\"21\">\n                 <div class=\"absolute bottom-0 right-0 w-3 h-3 bg-emerald-400 rounded-full border-2 border-[#1F305E] shadow-[0_0_10px_rgba(52,211,153,0.5)]\" data-kid=\"22\"></div>\n            </div>\n        </aside>\n\n        \n        <main class=\"flex-1 ml-20 lg:ml-24 p-8 lg:p-16\" data-kid=\"23\">\n            <div class=\"max-w-6xl mx-auto\" data-kid=\"24\">\n                \n                \n                <header class=\"flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8\" data-kid=\"25\">\n                    <div class=\"animate-header\" data-kid=\"26\">\n                        <span class=\"inline-block px-4 py-1.5 rounded-full bg-[#89CFF0]/10 border border-[#89CFF0]/20 text-[#89CFF0] text-xs font-semibold uppercase tracking-widest mb-4\" data-kid=\"27\">Métricas Ambientais</span>\n                        <h1 class=\"text-5xl lg:text-7xl font-['Plus_Jakarta_Sans'] font-extrabold tracking-tight leading-none mb-6\" data-kid=\"28\">\n                            Registros de <br data-kid=\"29\">\n                            <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[#89CFF0] to-[#FF9966]\" data-kid=\"30\">Temperatura</span>\n                        </h1>\n                        <p class=\"text-white/60 text-lg lg:text-xl max-w-xl\" data-kid=\"31\">\n                            Visualização detalhada da variabilidade térmica e fenômenos atmosféricos registrados nas últimas 24 horas em tempo real.\n                        </p>\n                    </div>\n\n                    <div class=\"flex items-center gap-4 glass-card p-2 animate-header\" data-kid=\"32\">\n                        <button class=\"px-8 py-3 rounded-xl bg-[#89CFF0]/20 text-white font-semibold transition-all hover:bg-[#89CFF0]/30\" data-kid=\"33\">Hoje</button>\n                        <button class=\"px-8 py-3 rounded-xl text-white/40 font-semibold hover:bg-white/5 transition-all\" data-kid=\"34\">Últimos 7 dias</button>\n                        <button class=\"w-12 h-12 flex items-center justify-center glass-card border-none hover:bg-white/10\" data-kid=\"35\">\n                            <i class=\"ph ph-calendar text-xl\" data-kid=\"36\"></i>\n                        </button>\n                    </div>\n                </header>\n\n                \n                <section class=\"relative py-10\" data-kid=\"37\">\n                    \n                    \n                    <div class=\"absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-[#89CFF0]/0 via-[#89CFF0]/40 to-[#89CFF0]/0 -translate-x-1/2 hidden md:block timeline-line-glow\" data-kid=\"38\"></div>\n\n                    <div class=\"space-y-24 md:space-y-16\" data-kid=\"39\">\n                        \n                        \n                        <div class=\"relative flex flex-col md:flex-row items-center justify-between timeline-item group\" data-side=\"left\" data-kid=\"40\">\n                            <div class=\"w-full md:w-[42%] text-left md:text-right\" data-kid=\"41\">\n                                <div class=\"glass-card p-8 group-hover:bg-white/10 transition-all duration-500 transform group-hover:-translate-y-2 group-hover:border-[#FF9966]/50\" data-kid=\"42\">\n                                    <div class=\"flex items-center md:flex-row-reverse gap-4 mb-6 pb-6 border-b border-white/5\" data-kid=\"43\">\n                                        <div class=\"w-14 h-14 rounded-2xl bg-[#FF9966]/20 flex items-center justify-center border border-[#FF9966]/30\" data-kid=\"44\">\n                                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sun.svg\" class=\"w-8 h-8\" alt=\"Hot\" data-kid=\"45\">\n                                        </div>\n                                        <div class=\"flex-1 md:text-right\" data-kid=\"46\">\n                                            <p class=\"text-[#FF9966] font-bold text-lg\" data-kid=\"47\">14:30 PM</p>\n                                            <p class=\"text-white/40 text-sm\" data-kid=\"48\">Pico Térmico</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"space-y-4\" data-kid=\"49\">\n                                        <div class=\"flex items-baseline md:justify-end gap-3\" data-kid=\"50\">\n                                            <h3 class=\"text-6xl font-['Plus_Jakarta_Sans'] font-extrabold text-[#FF9966] tracking-tight\" data-kid=\"51\">34.2°</h3>\n                                            <span class=\"text-white/40 text-2xl font-medium\" data-kid=\"52\">C</span>\n                                        </div>\n                                        <p class=\"text-white/85 leading-relaxed text-base\" data-kid=\"53\">\n                                            Incidência solar máxima registrada. Céu com pouca nebulosidade e ventos fracos (4km/h NW). Índice UV classificado como Extremo.\n                                        </p>\n                                        <div class=\"pt-6 flex flex-wrap md:justify-end gap-2\" data-kid=\"54\">\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"55\">UV 11+</span>\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"56\">Umidade 32%</span>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            \n                            <div class=\"hidden md:block absolute left-[42%] right-1/2 h-px bg-gradient-to-r from-transparent via-[#FF9966]/20 to-[#FF9966]/40 -translate-y-1/2 top-1/2 shadow-[0_0_10px_rgba(255,153,102,0.1)]\" data-kid=\"57\"></div>\n                            \n                            <div class=\"hidden md:flex absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full glass-card border-white/40 items-center justify-center z-20 group-hover:scale-125 transition-transform duration-500\" data-kid=\"58\">\n                                <div class=\"w-3 h-3 rounded-full bg-[#FF9966] node-glow-orange\" data-kid=\"59\"></div>\n                            </div>\n                            <div class=\"hidden md:block w-[42%]\" data-kid=\"60\"></div>\n                        </div>\n\n                        \n                        <div class=\"relative flex flex-col md:flex-row items-center justify-between timeline-item group\" data-side=\"right\" data-kid=\"61\">\n                            <div class=\"hidden md:block w-[42%]\" data-kid=\"62\"></div>\n                            \n                            <div class=\"hidden md:block absolute left-1/2 right-[42%] h-px bg-gradient-to-l from-transparent via-[#89CFF0]/20 to-[#89CFF0]/40 -translate-y-1/2 top-1/2 shadow-[0_0_10px_rgba(137,207,240,0.1)]\" data-kid=\"63\"></div>\n                            \n                            <div class=\"hidden md:flex absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full glass-card border-white/40 items-center justify-center z-20 group-hover:scale-125 transition-transform duration-500\" data-kid=\"64\">\n                                <div class=\"w-3 h-3 rounded-full bg-[#89CFF0] node-glow-blue\" data-kid=\"65\"></div>\n                            </div>\n                            <div class=\"w-full md:w-[42%]\" data-kid=\"66\">\n                                <div class=\"glass-card p-8 group-hover:bg-white/10 transition-all duration-500 transform group-hover:-translate-y-2 group-hover:border-[#89CFF0]/50\" data-kid=\"67\">\n                                    <div class=\"flex items-center gap-4 mb-6 pb-6 border-b border-white/5\" data-kid=\"68\">\n                                        <div class=\"w-14 h-14 rounded-2xl bg-[#89CFF0]/20 flex items-center justify-center border border-[#89CFF0]/30\" data-kid=\"69\">\n                                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sun-behind-large-cloud.svg\" class=\"w-8 h-8\" alt=\"Cloudy\" data-kid=\"70\">\n                                        </div>\n                                        <div class=\"flex-1\" data-kid=\"71\">\n                                            <p class=\"text-[#89CFF0] font-bold text-lg\" data-kid=\"72\">09:15 AM</p>\n                                            <p class=\"text-white/40 text-sm\" data-kid=\"73\">Transição Matinal</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"space-y-4\" data-kid=\"74\">\n                                        <div class=\"flex items-baseline gap-3\" data-kid=\"75\">\n                                            <h3 class=\"text-6xl font-['Plus_Jakarta_Sans'] font-extrabold text-[#89CFF0] tracking-tight\" data-kid=\"76\">22.8°</h3>\n                                            <span class=\"text-white/40 text-2xl font-medium\" data-kid=\"77\">C</span>\n                                        </div>\n                                        <p class=\"text-white/85 leading-relaxed text-base\" data-kid=\"78\">\n                                            Dissipação de névoa seca. Aumento gradual da temperatura sob influência de massa de ar tropical estável.\n                                        </p>\n                                        <div class=\"pt-6 flex flex-wrap gap-2\" data-kid=\"79\">\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"80\">Visibilidade 8km</span>\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"81\">Pressão 1012 hPa</span>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"relative flex flex-col md:flex-row items-center justify-between timeline-item group\" data-side=\"left\" data-kid=\"82\">\n                            <div class=\"w-full md:w-[42%] text-left md:text-right\" data-kid=\"83\">\n                                <div class=\"glass-card p-8 group-hover:bg-white/10 transition-all duration-500 transform group-hover:-translate-y-2 group-hover:border-[#89CFF0]/50\" data-kid=\"84\">\n                                    <div class=\"flex items-center md:flex-row-reverse gap-4 mb-6 pb-6 border-b border-white/5\" data-kid=\"85\">\n                                        <div class=\"w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center border border-white/20\" data-kid=\"86\">\n                                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/cloud-with-rain.svg\" class=\"w-8 h-8\" alt=\"Rain\" data-kid=\"87\">\n                                        </div>\n                                        <div class=\"flex-1 md:text-right\" data-kid=\"88\">\n                                            <p class=\"text-white/60 font-bold text-lg\" data-kid=\"89\">04:45 AM</p>\n                                            <p class=\"text-white/40 text-sm\" data-kid=\"90\">Mínima Estável</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"space-y-4\" data-kid=\"91\">\n                                        <div class=\"flex items-baseline md:justify-end gap-3\" data-kid=\"92\">\n                                            <h3 class=\"text-6xl font-['Plus_Jakarta_Sans'] font-extrabold text-white/85 tracking-tight\" data-kid=\"93\">18.5°</h3>\n                                            <span class=\"text-white/40 text-2xl font-medium\" data-kid=\"94\">C</span>\n                                        </div>\n                                        <p class=\"text-white/85 leading-relaxed text-base\" data-kid=\"95\">\n                                            Período de menor atividade térmica. Precipitação leve acumulada (1.2mm) favorecendo o resfriamento radiativo da superfície.\n                                        </p>\n                                        <div class=\"pt-6 flex flex-wrap md:justify-end gap-2\" data-kid=\"96\">\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"97\">Ponto de Orvalho 17°</span>\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"98\">Calmo</span>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            \n                            <div class=\"hidden md:block absolute left-[42%] right-1/2 h-px bg-gradient-to-r from-transparent to-white/10 -translate-y-1/2 top-1/2\" data-kid=\"99\"></div>\n                            \n                            <div class=\"hidden md:flex absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full glass-card border-white/40 items-center justify-center z-20 group-hover:scale-125 transition-transform duration-500\" data-kid=\"100\">\n                                <div class=\"w-3 h-3 rounded-full bg-white/40 shadow-[0_0_10px_rgba(255,255,255,0.3)]\" data-kid=\"101\"></div>\n                            </div>\n                            <div class=\"hidden md:block w-[42%]\" data-kid=\"102\"></div>\n                        </div>\n\n                        \n                        <div class=\"relative flex flex-col md:flex-row items-center justify-between timeline-item group\" data-side=\"right\" data-kid=\"103\">\n                            <div class=\"hidden md:block w-[42%]\" data-kid=\"104\"></div>\n                            \n                            <div class=\"hidden md:block absolute left-1/2 right-[42%] h-px bg-gradient-to-l from-transparent to-[#89CFF0]/30 -translate-y-1/2 top-1/2\" data-kid=\"105\"></div>\n                            \n                            <div class=\"hidden md:flex absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full glass-card border-white/40 items-center justify-center z-20 group-hover:scale-125 transition-transform duration-500\" data-kid=\"106\">\n                                <div class=\"w-3 h-3 rounded-full bg-[#89CFF0] node-glow-blue\" data-kid=\"107\"></div>\n                            </div>\n                            <div class=\"w-full md:w-[42%]\" data-kid=\"108\">\n                                <div class=\"glass-card p-8 group-hover:bg-white/10 transition-all duration-500 transform group-hover:-translate-y-2 group-hover:border-[#89CFF0]/50\" data-kid=\"109\">\n                                    <div class=\"flex items-center gap-4 mb-6 pb-6 border-b border-white/5\" data-kid=\"110\">\n                                        <div class=\"w-14 h-14 rounded-2xl bg-[#89CFF0]/20 flex items-center justify-center border border-[#89CFF0]/30\" data-kid=\"111\">\n                                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/cloud-with-lightning-and-rain.svg\" class=\"w-8 h-8\" alt=\"Storm\" data-kid=\"112\">\n                                        </div>\n                                        <div class=\"flex-1\" data-kid=\"113\">\n                                            <p class=\"text-[#89CFF0] font-bold text-lg\" data-kid=\"114\">11:00 PM</p>\n                                            <p class=\"text-white/40 text-sm\" data-kid=\"115\">Registro Noturno</p>\n                                        </div>\n                                    </div>\n                                    <div class=\"space-y-4\" data-kid=\"116\">\n                                        <div class=\"flex items-baseline gap-3\" data-kid=\"117\">\n                                            <h3 class=\"text-6xl font-['Plus_Jakarta_Sans'] font-extrabold text-[#89CFF0] tracking-tight\" data-kid=\"118\">21.1°</h3>\n                                            <span class=\"text-white/40 text-2xl font-medium\" data-kid=\"119\">C</span>\n                                        </div>\n                                        <p class=\"text-white/85 leading-relaxed text-base\" data-kid=\"120\">\n                                            Trovoada isolada com rajadas de vento (22km/h SE). Queda brusca de 4°C em menos de 30 minutos devido à passagem de frente fria.\n                                        </p>\n                                        <div class=\"pt-6 flex flex-wrap gap-2\" data-kid=\"121\">\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"122\">Vento SE</span>\n                                            <span class=\"px-3 py-1 rounded-lg bg-white/5 border border-white/10 text-xs text-white/50\" data-kid=\"123\">Umidade 92%</span>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n                    </div>\n                </section>\n\n                \n                <footer class=\"mt-32 glass-card p-10 flex flex-col md:flex-row items-center justify-between gap-10 animate-footer\" data-kid=\"124\">\n                    <div class=\"flex-1\" data-kid=\"125\">\n                        <h4 class=\"text-2xl font-bold font-['Plus_Jakarta_Sans'] mb-2\" data-kid=\"126\">Resumo de Tendência</h4>\n                        <p class=\"text-white/50\" data-kid=\"127\">Com base nos dados coletados, espera-se estabilidade térmica nas próximas 12 horas com baixa probabilidade de precipitação significativa.</p>\n                    </div>\n                    <div class=\"flex gap-12\" data-kid=\"128\">\n                        <div class=\"text-center\" data-kid=\"129\">\n                            <p class=\"text-white/60 text-[10px] font-bold uppercase tracking-widest mb-2\" data-kid=\"130\">Média</p>\n                            <p class=\"text-3xl font-bold text-[#89CFF0] tracking-tighter\" data-kid=\"131\">24.2°</p>\n                        </div>\n                        <div class=\"text-center\" data-kid=\"132\">\n                            <p class=\"text-white/60 text-[10px] font-bold uppercase tracking-widest mb-2\" data-kid=\"133\">Variação</p>\n                            <p class=\"text-3xl font-bold text-[#FF9966] tracking-tighter\" data-kid=\"134\">15.7°</p>\n                        </div>\n                        <div class=\"text-center\" data-kid=\"135\">\n                            <p class=\"text-white/60 text-[10px] font-bold uppercase tracking-widest mb-2\" data-kid=\"136\">Confiabilidade</p>\n                            <p class=\"text-3xl font-bold text-emerald-400 tracking-tighter drop-shadow-[0_0_8px_rgba(52,211,153,0.3)]\" data-kid=\"137\">98%</p>\n                        </div>\n                    </div>\n                </footer>\n            </div>\n        </main>\n    </div>\n\n    \n    <script src=\"https://unpkg.com/@phosphor-icons/web\" data-kid=\"138\"></script>\n    \n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"139\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"140\"></script>\n    <script data-kid=\"141\">\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Initial Header Animation\n        gsap.from(\".animate-header\", {\n            y: 50,\n            opacity: 0,\n            duration: 1.2,\n            stagger: 0.2,\n            ease: \"power4.out\"\n        });\n\n        // Timeline Items Animation\n        const items = document.querySelectorAll('.timeline-item');\n        items.forEach((item, index) => {\n            const side = item.getAttribute('data-side');\n            const xOffset = side === 'left' ? -100 : 100;\n            \n            gsap.from(item, {\n                scrollTrigger: {\n                    trigger: item,\n                    start: \"top 85%\",\n                    toggleActions: \"play none none none\"\n                },\n                x: xOffset,\n                opacity: 0,\n                duration: 1,\n                ease: \"power3.out\",\n                delay: index * 0.1\n            });\n        });\n\n        // Footer Animation\n        gsap.from(\".animate-footer\", {\n            scrollTrigger: {\n                trigger: \".animate-footer\",\n                start: \"top 95%\"\n            },\n            y: 50,\n            opacity: 0,\n            duration: 1,\n            ease: \"power3.out\"\n        });\n    </script>\n</body>\n",
