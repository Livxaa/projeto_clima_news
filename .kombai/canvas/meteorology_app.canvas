      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Figtree:wght@300;400;500;600;700&display=swap');\n  \n  :root {\n    --indigo-60: #1F305E;\n    --baby-blue-30: #89CFF0;\n    --tangerine-10: #FF9966;\n  }\n\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n  .font-body { font-family: 'Figtree', sans-serif; }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.08);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.15);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);\n  }\n\n  .glass-pill {\n    background: rgba(255, 255, 255, 0.15);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .blob {\n    filter: blur(120px);\n    border-radius: 50%;\n    position: absolute;\n    z-index: 0;\n    pointer-events: none;\n  }\n\n  .sidebar-link.active {\n    background: rgba(255, 255, 255, 0.15);\n    color: var(--baby-blue-30);\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-20px); }\n  }\n  .animate-float { animation: float 6s ease-in-out infinite; }\n\n  @keyframes bounce-slow {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-10px); }\n  }\n  .animate-bounce-slow { animation: bounce-slow 4s ease-in-out infinite; }\n\n  .chart-path {\n    stroke-dasharray: 2000;\n    stroke-dashoffset: 2000;\n  }\n\n  /* Lenis CSS */\n  html.lenis, html.lenis body { height: auto; }\n  .lenis.lenis-smooth { scroll-behavior: auto !important; }\n  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }\n  .lenis.lenis-stopped { overflow: hidden; }\n  .lenis.lenis-scrolling iframe { pointer-events: none; }\n</style>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<div class=\"bg-[var(--indigo-60)] font-body text-white min-h-screen relative overflow-hidden\" data-kid=\"2\">\n  \n  <div class=\"fixed inset-0 z-0 overflow-hidden pointer-events-none\" data-kid=\"3\">\n    <div class=\"blob blob-1 w-[800px] h-[800px] bg-[#89CFF0]/40 top-[-20%] left-[-10%]\" data-kid=\"4\"></div>\n    <div class=\"blob blob-2 w-[600px] h-[600px] bg-[#FF9966]/30 bottom-[-10%] right-[-5%]\" data-kid=\"5\"></div>\n    <div class=\"blob blob-3 w-[500px] h-[500px] bg-[#89CFF0]/25 top-[40%] right-[15%]\" data-kid=\"6\"></div>\n    <div class=\"blob blob-4 w-[700px] h-[700px] bg-[#FF9966]/20 bottom-[20%] left-[10%]\" data-kid=\"7\"></div>\n  </div>\n\n  <div class=\"relative z-10 flex min-h-screen\" data-kid=\"8\">\n    \n    <aside class=\"w-24 lg:w-72 glass h-screen sticky top-0 border-r border-white/10 hidden md:flex flex-col py-10 px-6 shrink-0\" data-kid=\"9\">\n      <div class=\"flex items-center gap-3 mb-16 px-4\" data-kid=\"10\">\n        <div class=\"w-10 h-10 bg-[var(--baby-blue-30)] rounded-xl flex items-center justify-center\" data-kid=\"11\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6 text-[#1F305E]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"12\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" d=\"M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z\" data-kid=\"13\"></path>\n          </svg>\n        </div>\n        <span class=\"text-xl font-bold font-heading hidden lg:block\" data-kid=\"14\">Atmos<span class=\"text-[var(--baby-blue-30)]\" data-kid=\"15\">Cloud</span></span>\n      </div>\n\n      <nav class=\"flex-1 space-y-4\" data-kid=\"16\">\n        <a href=\"#\" class=\"sidebar-link active flex items-center gap-4 p-4 rounded-2xl\" data-kid=\"17\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"18\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z\" data-kid=\"19\"></path>\n          </svg>\n          <span class=\"font-medium hidden lg:block\" data-kid=\"20\">Dashboard</span>\n        </a>\n        <a href=\"#\" class=\"sidebar-link flex items-center gap-4 p-4 rounded-2xl text-white/50 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"21\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"22\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\" data-kid=\"23\"></path>\n          </svg>\n          <span class=\"font-medium hidden lg:block\" data-kid=\"24\">Reports</span>\n        </a>\n        <a href=\"#\" class=\"sidebar-link flex items-center gap-4 p-4 rounded-2xl text-white/50 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"25\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"26\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" data-kid=\"27\"></path>\n          </svg>\n          <span class=\"font-medium hidden lg:block\" data-kid=\"28\">History</span>\n        </a>\n      </nav>\n\n      <div class=\"mt-auto\" data-kid=\"29\">\n        <div class=\"glass p-5 rounded-3xl hidden lg:block border border-white/5\" data-kid=\"30\">\n          <p class=\"text-[10px] text-white/40 font-bold uppercase tracking-widest mb-3\" data-kid=\"31\">System Alert</p>\n          <p class=\"text-xs font-medium text-white/80 leading-relaxed\" data-kid=\"32\">Moderate rainfall expected in Oslo region within next 2h.</p>\n        </div>\n        <div class=\"mt-8 flex items-center gap-4 px-2\" data-kid=\"33\">\n          <img src=\"https://i.pravatar.cc/100?u=meteorologist\" class=\"w-10 h-10 rounded-full border-2 border-[var(--baby-blue-30)]\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"34\">\n          <div class=\"hidden lg:block overflow-hidden\" data-kid=\"35\">\n            <p class=\"font-bold text-sm truncate\" data-kid=\"36\">Dr. Sarah Jenkins</p>\n            <p class=\"text-[10px] text-white/40 uppercase font-bold tracking-wider truncate\" data-kid=\"37\">Senior Analyst</p>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <main class=\"flex-1 px-6 lg:px-12 py-10 max-w-[1600px] mx-auto overflow-hidden\" data-kid=\"38\">\n      \n      <header class=\"flex flex-col sm:flex-row justify-between items-start sm:items-center mb-16 gap-6 animate-header\" data-kid=\"39\">\n        <div data-kid=\"40\">\n          <h1 class=\"text-4xl lg:text-5xl font-extrabold font-heading tracking-tight\" data-kid=\"41\">Meteorology <span class=\"text-[var(--baby-blue-30)]\" data-kid=\"42\">Hub</span></h1>\n          <p class=\"text-white/60 mt-2 text-lg\" data-kid=\"43\">Real-time data for Oslo, Norway • Monday, Oct 12</p>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"44\">\n          <div class=\"glass px-6 py-3 rounded-2xl flex items-center gap-4 border border-white/10\" data-kid=\"45\">\n             <div class=\"flex flex-col\" data-kid=\"46\">\n               <span class=\"text-[9px] uppercase font-bold text-white/30 tracking-widest\" data-kid=\"47\">Station ID</span>\n               <span class=\"text-sm font-bold font-heading\" data-kid=\"48\">OSL-4429</span>\n             </div>\n             <div class=\"w-px h-8 bg-white/10\" data-kid=\"49\"></div>\n             <div class=\"flex items-center gap-3\" data-kid=\"50\">\n               <span class=\"w-2 h-2 rounded-full bg-green-400 animate-pulse\" data-kid=\"51\"></span>\n               <span class=\"text-xs font-bold tracking-widest uppercase\" data-kid=\"52\">Live Feed</span>\n             </div>\n          </div>\n        </div>\n      </header>\n\n      \n      <section class=\"grid grid-cols-12 gap-6 auto-rows-[220px] mb-12\" id=\"dashboard-grid\" data-kid=\"53\">\n        \n        <div class=\"col-span-12 lg:col-span-8 row-span-2 glass rounded-[3rem] p-10 flex flex-col justify-between overflow-hidden relative group card-reveal border border-white/20\" data-kid=\"54\">\n          <div class=\"relative z-10\" data-kid=\"55\">\n            <div class=\"flex flex-col md:flex-row justify-between items-start\" data-kid=\"56\">\n              <div data-kid=\"57\">\n                <p class=\"text-[var(--baby-blue-30)] font-bold tracking-[0.2em] uppercase text-[10px] mb-4\" data-kid=\"58\">Current Atmospheric Conditions</p>\n                <h2 class=\"text-8xl font-extrabold text-white font-heading tracking-tighter\" data-kid=\"59\">14.2°<span class=\"text-[var(--tangerine-10)]\" data-kid=\"60\">C</span></h2>\n                <p class=\"text-white/70 text-xl mt-4 flex items-center gap-3 font-medium\" data-kid=\"61\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6 text-[var(--baby-blue-30)]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"62\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" d=\"M19 14l-7 7m0 0l-7-7m7 7V3\" data-kid=\"63\"></path>\n                  </svg>\n                  Partly cloudy with localized showers\n                </p>\n              </div>\n              <div class=\"w-48 h-48 flex items-center justify-center mt-6 md:mt-0\" data-kid=\"64\">\n                 <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sun-behind-rain-cloud.svg\" class=\"w-full h-full drop-shadow-[0_0_40px_rgba(255,153,102,0.4)] animate-float\" alt=\"Weather Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"65\">\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 mt-auto relative z-10 pt-10 border-t border-white/10\" data-kid=\"66\">\n            <div data-kid=\"67\">\n              <p class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em] mb-2\" data-kid=\"68\">Humidity</p>\n              <p class=\"text-white text-2xl font-bold font-heading\" data-kid=\"69\">78%</p>\n            </div>\n            <div data-kid=\"70\">\n              <p class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em] mb-2\" data-kid=\"71\">Pressure</p>\n              <p class=\"text-white text-2xl font-bold font-heading\" data-kid=\"72\">1012.4 <span class=\"text-sm font-medium opacity-30\" data-kid=\"73\">hPa</span></p>\n            </div>\n            <div data-kid=\"74\">\n              <p class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em] mb-2\" data-kid=\"75\">Visibility</p>\n              <p class=\"text-white text-2xl font-bold font-heading\" data-kid=\"76\">12.5 <span class=\"text-sm font-medium opacity-30\" data-kid=\"77\">km</span></p>\n            </div>\n            <div data-kid=\"78\">\n              <p class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em] mb-2\" data-kid=\"79\">UV Index</p>\n              <p class=\"text-white text-2xl font-bold font-heading\" data-kid=\"80\">2.4 <span class=\"text-xs font-bold uppercase tracking-widest ml-1 text-green-400\" data-kid=\"81\">Low</span></p>\n            </div>\n          </div>\n          \n          <video src=\"https://videos.pexels.com/video-files/5700806/5700806-hd_1920_1080_25fps.mp4\" poster=\"https://images.pexels.com/videos/5700806/pexels-photo-5700806.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" class=\"absolute inset-0 w-full h-full object-cover opacity-15 group-hover:opacity-25 transition-opacity duration-1000 pointer-events-none\" muted loop autoplay playsinline preload=\"metadata\" data-kid=\"82\"></video>\n        </div>\n\n        \n        <div class=\"col-span-12 md:col-span-6 lg:col-span-4 row-span-1 glass rounded-[3rem] p-10 flex flex-col justify-between card-reveal border border-white/10 group\" data-kid=\"83\">\n          <div class=\"flex justify-between items-start\" data-kid=\"84\">\n            <div data-kid=\"85\">\n              <p class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em]\" data-kid=\"86\">Daily Extremes</p>\n              <div class=\"flex items-end gap-4 mt-3\" data-kid=\"87\">\n                <span class=\"text-6xl font-extrabold text-[var(--tangerine-10)] font-heading tracking-tighter\" data-kid=\"88\">18°</span>\n                <span class=\"text-white/20 text-4xl font-light\" data-kid=\"89\">/</span>\n                <span class=\"text-6xl font-extrabold text-[var(--baby-blue-30)] font-heading tracking-tighter\" data-kid=\"90\">9°</span>\n              </div>\n            </div>\n            <div class=\"p-4 bg-white/5 rounded-2xl\" data-kid=\"91\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-7 h-7 text-[var(--tangerine-10)]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"92\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\" data-kid=\"93\"></path>\n              </svg>\n            </div>\n          </div>\n          <div class=\"w-full mt-6\" data-kid=\"94\">\n             <div class=\"w-full h-3 bg-white/5 rounded-full overflow-hidden relative\" data-kid=\"95\">\n               <div class=\"absolute inset-0 bg-gradient-to-r from-[var(--baby-blue-30)] to-[var(--tangerine-10)] w-[70%] rounded-full shadow-[0_0_20px_rgba(137,207,240,0.5)]\" data-kid=\"96\"></div>\n             </div>\n             <p class=\"text-[10px] text-white/40 mt-4 font-bold tracking-widest uppercase\" data-kid=\"97\">Currently 4° above historical avg</p>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 md:col-span-6 lg:col-span-4 row-span-1 glass rounded-[3rem] p-10 flex flex-col justify-between card-reveal border border-white/10 group\" data-kid=\"98\">\n          <div class=\"flex justify-between items-center\" data-kid=\"99\">\n            <p class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em]\" data-kid=\"100\">Wind Vector</p>\n            <span class=\"px-3 py-1 bg-[var(--baby-blue-30)]/10 text-[var(--baby-blue-30)] text-[10px] font-bold rounded-lg tracking-widest\" data-kid=\"101\">NW 24°</span>\n          </div>\n          <div class=\"flex items-center gap-8 py-4\" data-kid=\"102\">\n            <div class=\"w-20 h-20 rounded-full border-2 border-white/10 flex items-center justify-center relative\" data-kid=\"103\">\n               <div class=\"w-1.5 h-12 bg-gradient-to-t from-[var(--baby-blue-30)] to-transparent rounded-full rotate-[120deg] origin-center shadow-[0_0_15px_var(--baby-blue-30)]\" data-kid=\"104\"></div>\n               <div class=\"absolute -top-3 left-1/2 -translate-x-1/2 text-[9px] font-bold text-white/30 tracking-widest\" data-kid=\"105\">N</div>\n            </div>\n            <div data-kid=\"106\">\n              <p class=\"text-5xl font-extrabold text-white font-heading tracking-tighter\" data-kid=\"107\">12.4 <span class=\"text-xl font-medium opacity-30\" data-kid=\"108\">km/h</span></p>\n              <p class=\"text-[10px] text-white/40 mt-2 font-bold tracking-[0.1em] uppercase\" data-kid=\"109\">Sustained light breeze</p>\n            </div>\n          </div>\n          <button class=\"w-full py-3 bg-white/5 rounded-2xl text-[10px] font-bold uppercase tracking-[0.2em] border border-white/5\" data-kid=\"110\">Analyze Vector Details</button>\n        </div>\n      </section>\n\n      \n      <section class=\"mb-24 card-reveal\" id=\"trends\" data-kid=\"111\">\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-10 gap-6\" data-kid=\"112\">\n          <div data-kid=\"113\">\n            <h3 class=\"text-4xl font-extrabold font-heading tracking-tight\" data-kid=\"114\">Atmospheric Trends</h3>\n            <p class=\"text-white/50 mt-3 text-lg font-medium\" data-kid=\"115\">Predictive projection for the next 24-hour cycle</p>\n          </div>\n          <div class=\"flex gap-3 glass p-1.5 rounded-2xl border border-white/10\" data-kid=\"116\">\n            <button class=\"px-6 py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest text-white/50 hover:text-white transition-all\" data-kid=\"117\">Daily</button>\n            <button class=\"px-6 py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest bg-[var(--baby-blue-30)] text-[#1F305E] shadow-xl\" data-kid=\"118\">24h Cycle</button>\n            <button class=\"px-6 py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest text-white/50 hover:text-white transition-all\" data-kid=\"119\">Week</button>\n          </div>\n        </div>\n\n        <div class=\"relative glass rounded-[3.5rem] p-12 h-[500px] flex items-end overflow-hidden group border border-white/10\" data-kid=\"120\">\n          \n          <div class=\"absolute inset-0 p-12 flex flex-col justify-between pointer-events-none opacity-5\" data-kid=\"121\">\n            <div class=\"w-full h-px bg-white\" data-kid=\"122\"></div>\n            <div class=\"w-full h-px bg-white\" data-kid=\"123\"></div>\n            <div class=\"w-full h-px bg-white\" data-kid=\"124\"></div>\n            <div class=\"w-full h-px bg-white\" data-kid=\"125\"></div>\n            <div class=\"w-full h-px bg-white\" data-kid=\"126\"></div>\n            <div class=\"w-full h-px bg-white\" data-kid=\"127\"></div>\n          </div>\n\n          \n          <svg class=\"w-full h-full relative z-10 overflow-visible\" viewBox=\"0 0 1000 300\" preserveAspectRatio=\"none\" data-kid=\"128\">\n            <defs data-kid=\"129\">\n              <linearGradient id=\"lineGradFinal\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\" data-kid=\"130\">\n                <stop offset=\"0%\" stop-color=\"#89CFF0\" data-kid=\"131\"></stop>\n                <stop offset=\"40%\" stop-color=\"#FF9966\" data-kid=\"132\"></stop>\n                <stop offset=\"70%\" stop-color=\"#89CFF0\" data-kid=\"133\"></stop>\n                <stop offset=\"100%\" stop-color=\"#89CFF0\" data-kid=\"134\"></stop>\n              </linearGradient>\n              <filter id=\"glowFinal\" data-kid=\"135\">\n                <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\" data-kid=\"136\"></feGaussianBlur>\n                <feMerge data-kid=\"137\">\n                    <feMergeNode in=\"coloredBlur\" data-kid=\"138\"></feMergeNode>\n                    <feMergeNode in=\"SourceGraphic\" data-kid=\"139\"></feMergeNode>\n                </feMerge>\n              </filter>\n            </defs>\n            <path d=\"M0,280 C150,250 250,80 400,100 C550,120 700,280 850,150 C950,50 1000,40 1000,40\" fill=\"none\" stroke=\"url(#lineGradFinal)\" stroke-width=\"7\" stroke-linecap=\"round\" class=\"chart-path-final\" filter=\"url(#glowFinal)\" data-kid=\"140\"></path>\n            \n            \n            <circle cx=\"400\" cy=\"100\" r=\"10\" fill=\"var(--tangerine-10)\" class=\"animate-pulse shadow-[0_0_20px_var(--tangerine-10)]\" data-kid=\"141\"></circle>\n            <circle cx=\"850\" cy=\"150\" r=\"8\" fill=\"var(--baby-blue-30)\" class=\"shadow-[0_0_20px_var(--baby-blue-30)]\" data-kid=\"142\"></circle>\n          </svg>\n\n          \n          <div class=\"absolute\" style=\"top: 15%; left: 38%;\" data-kid=\"143\">\n            <div class=\"glass-pill px-6 py-4 rounded-[2rem] flex flex-col items-center animate-bounce-slow border border-white/20\" data-kid=\"144\">\n              <span class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em] mb-1\" data-kid=\"145\">Peak Intensity</span>\n              <span class=\"text-white font-extrabold text-2xl font-heading tracking-tighter\" data-kid=\"146\">19.5°C</span>\n              <div class=\"w-px h-8 bg-white/20 mt-3\" data-kid=\"147\"></div>\n            </div>\n          </div>\n\n          <div class=\"absolute\" style=\"top: 58%; left: 81%;\" data-kid=\"148\">\n            <div class=\"glass-pill px-6 py-4 rounded-[2rem] flex flex-col items-center border border-white/20\" data-kid=\"149\">\n              <span class=\"text-white/40 text-[9px] uppercase font-bold tracking-[0.2em] mb-1\" data-kid=\"150\">Cooling Wave</span>\n              <span class=\"text-white font-extrabold text-2xl font-heading tracking-tighter\" data-kid=\"151\">-3.2°C</span>\n              <div class=\"w-px h-8 bg-white/20 mt-3\" data-kid=\"152\"></div>\n            </div>\n          </div>\n\n          \n          <div class=\"absolute bottom-8 left-12 right-12 flex justify-between text-white/30 text-[10px] font-bold tracking-[0.3em] font-heading uppercase\" data-kid=\"153\">\n            <span data-kid=\"154\">06:00 AM</span>\n            <span data-kid=\"155\">09:00 AM</span>\n            <span data-kid=\"156\">12:00 PM</span>\n            <span data-kid=\"157\">03:00 PM</span>\n            <span data-kid=\"158\">06:00 PM</span>\n            <span data-kid=\"159\">09:00 PM</span>\n            <span data-kid=\"160\">12:00 AM</span>\n          </div>\n        </div>\n      </section>\n\n      \n      <div class=\"grid grid-cols-12 gap-16\" data-kid=\"161\">\n        \n        <div class=\"col-span-12 xl:col-span-5 card-reveal\" id=\"logs\" data-kid=\"162\">\n          <div class=\"mb-12\" data-kid=\"163\">\n            <h3 class=\"text-4xl font-extrabold font-heading tracking-tight\" data-kid=\"164\">Activity Stream</h3>\n            <p class=\"text-white/50 mt-3 text-lg font-medium\" data-kid=\"165\">Sequence of recorded atmospheric events</p>\n          </div>\n\n          <div class=\"relative pl-8\" data-kid=\"166\">\n            \n            <div class=\"absolute left-0 top-4 bottom-0 w-[2px] bg-gradient-to-b from-[var(--baby-blue-30)] via-[var(--tangerine-10)] to-transparent opacity-30\" data-kid=\"167\"></div>\n\n            <div class=\"space-y-12\" data-kid=\"168\">\n              \n              <div class=\"flex items-center w-full relative\" data-kid=\"169\">\n                <div class=\"w-full glass p-8 rounded-[2.5rem] border-l-4 border-l-[var(--baby-blue-30)] group hover:bg-white/10 transition-transform duration-500 hover:translate-y-[-5px]\" data-kid=\"170\">\n                  <div class=\"flex justify-between items-center mb-3\" data-kid=\"171\">\n                    <span class=\"text-[var(--baby-blue-30)] text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"172\">10:45 AM</span>\n                    <span class=\"w-2 h-2 rounded-full bg-[var(--baby-blue-30)] animate-pulse\" data-kid=\"173\"></span>\n                  </div>\n                  <h4 class=\"text-white text-xl font-extrabold font-heading tracking-tight mt-1\" data-kid=\"174\">Thermal Uplift</h4>\n                  <p class=\"text-white/60 text-sm mt-3 leading-relaxed font-medium\" data-kid=\"175\">Convection currents detected at station OSL-4. Surface pressure remains stable at 1012.4 hPa.</p>\n                </div>\n                <div class=\"w-5 h-5 rounded-full bg-[var(--baby-blue-30)] border-4 border-[#1F305E] z-10 absolute left-0 -translate-x-1/2 shadow-[0_0_20px_var(--baby-blue-30)]\" data-kid=\"176\"></div>\n              </div>\n\n              \n              <div class=\"flex items-center w-full relative\" data-kid=\"177\">\n                <div class=\"w-full glass p-8 rounded-[2.5rem] border-l-4 border-l-[var(--tangerine-10)] group hover:bg-white/10 transition-transform duration-500 hover:translate-y-[-5px]\" data-kid=\"178\">\n                  <div class=\"flex justify-between items-center mb-3\" data-kid=\"179\">\n                    <span class=\"text-[var(--tangerine-10)] text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"180\">09:12 AM</span>\n                    <span class=\"w-2 h-2 rounded-full bg-[var(--tangerine-10)]\" data-kid=\"181\"></span>\n                  </div>\n                  <h4 class=\"text-white text-xl font-extrabold font-heading tracking-tight mt-1\" data-kid=\"182\">Solar Peak</h4>\n                  <p class=\"text-white/60 text-sm mt-3 leading-relaxed font-medium\" data-kid=\"183\">Global irradiance hit 850 W/m². Protective ozone layer within normal bounds.</p>\n                </div>\n                <div class=\"w-5 h-5 rounded-full bg-[var(--tangerine-10)] border-4 border-[#1F305E] z-10 absolute left-0 -translate-x-1/2 shadow-[0_0_20px_var(--tangerine-10)]\" data-kid=\"184\"></div>\n              </div>\n\n              \n              <div class=\"flex items-center w-full relative\" data-kid=\"185\">\n                <div class=\"w-full glass p-8 rounded-[2.5rem] border-l-4 border-l-[var(--baby-blue-30)] group hover:bg-white/10 transition-transform duration-500 hover:translate-y-[-5px]\" data-kid=\"186\">\n                  <div class=\"flex justify-between items-center mb-3\" data-kid=\"187\">\n                    <span class=\"text-[var(--baby-blue-30)] text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"188\">07:30 AM</span>\n                    <span class=\"w-2 h-2 rounded-full bg-[var(--baby-blue-30)] opacity-50\" data-kid=\"189\"></span>\n                  </div>\n                  <h4 class=\"text-white text-xl font-extrabold font-heading tracking-tight mt-1\" data-kid=\"190\">Mist Saturation</h4>\n                  <p class=\"text-white/60 text-sm mt-3 leading-relaxed font-medium\" data-kid=\"191\">Relative humidity reached saturation at 98%. Visibility reduced to 800m.</p>\n                </div>\n                <div class=\"w-5 h-5 rounded-full bg-[var(--baby-blue-30)] border-4 border-[#1F305E] z-10 absolute left-0 -translate-x-1/2 shadow-[0_0_20px_var(--baby-blue-30)]\" data-kid=\"192\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 xl:col-span-7 card-reveal\" id=\"reports\" data-kid=\"193\">\n          <div class=\"mb-12 flex justify-between items-center\" data-kid=\"194\">\n            <div data-kid=\"195\">\n              <h3 class=\"text-4xl font-extrabold font-heading tracking-tight\" data-kid=\"196\">Analytical Reports</h3>\n              <p class=\"text-white/50 mt-3 text-lg font-medium\" data-kid=\"197\">Deep-dive summaries into seasonal shifts</p>\n            </div>\n            <div class=\"flex gap-4\" data-kid=\"198\">\n              <button class=\"w-14 h-14 glass rounded-full flex items-center justify-center text-white/50 hover:text-white transition-all border border-white/10\" id=\"carousel-prev\" data-kid=\"199\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"200\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M15 19l-7-7 7-7\" data-kid=\"201\"></path>\n                </svg>\n              </button>\n              <button class=\"w-14 h-14 glass rounded-full flex items-center justify-center text-white/50 hover:text-white transition-all border border-white/10\" id=\"carousel-next\" data-kid=\"202\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"203\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" d=\"M9 5l7 7-7 7\" data-kid=\"204\"></path>\n                </svg>\n              </button>\n            </div>\n          </div>\n\n          <div class=\"carousel-container flex gap-10 overflow-x-auto no-scrollbar snap-x py-6 px-4 scroll-smooth\" data-kid=\"205\">\n            \n            <div class=\"min-w-[460px] h-[400px] glass rounded-[3.5rem] p-12 flex flex-col justify-between shrink-0 snap-center relative overflow-hidden group hover:scale-[1.03] transition-all duration-700 border border-white/10\" data-kid=\"206\">\n              <div class=\"absolute -right-20 -top-20 w-64 h-64 bg-[var(--baby-blue-30)]/10 rounded-full blur-[100px] group-hover:bg-[var(--baby-blue-30)]/25 transition-all duration-1000\" data-kid=\"207\"></div>\n              <div class=\"relative z-10\" data-kid=\"208\">\n                <div class=\"w-16 h-16 glass rounded-2xl flex items-center justify-center mb-8 border border-white/10 group-hover:bg-white/15 transition-all\" data-kid=\"209\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-9 h-9 text-[var(--baby-blue-30)]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"210\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" data-kid=\"211\"></path>\n                  </svg>\n                </div>\n                <h4 class=\"text-3xl font-extrabold text-white mb-4 font-heading tracking-tight\" data-kid=\"212\">Coastal Pressure Cycle</h4>\n                <p class=\"text-white/50 text-base leading-relaxed line-clamp-3 font-medium\" data-kid=\"213\">Barometric anomalies over the North Sea indicate a potential cyclonic formation. This report analyzes the last 48h of high-resolution sensor data.</p>\n              </div>\n              <div class=\"flex justify-between items-center relative z-10\" data-kid=\"214\">\n                <div class=\"flex -space-x-3\" data-kid=\"215\">\n                  <img src=\"https://i.pravatar.cc/100?u=sarah\" class=\"w-12 h-12 rounded-full border-2 border-[#1F305E] shadow-xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"216\">\n                  <img src=\"https://i.pravatar.cc/100?u=mark\" class=\"w-12 h-12 rounded-full border-2 border-[#1F305E] shadow-xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"217\">\n                  <div class=\"w-12 h-12 rounded-full border-2 border-[#1F305E] bg-white/10 backdrop-blur-md flex items-center justify-center text-xs font-bold font-heading\" data-kid=\"218\">+3</div>\n                </div>\n                <button class=\"px-8 py-4 bg-[var(--baby-blue-30)] text-[#1F305E] font-extrabold rounded-[1.5rem] text-[10px] uppercase tracking-[0.2em] hover:scale-105 transition-all shadow-2xl\" data-kid=\"219\">Read Full Analysis</button>\n              </div>\n            </div>\n\n            \n            <div class=\"min-w-[460px] h-[400px] glass rounded-[3.5rem] p-12 flex flex-col justify-between shrink-0 snap-center relative overflow-hidden group hover:scale-[1.03] transition-all duration-700 border border-white/10 opacity-60 hover:opacity-100\" data-kid=\"220\">\n              <div class=\"absolute -right-20 -top-20 w-64 h-64 bg-[var(--tangerine-10)]/10 rounded-full blur-[100px] group-hover:bg-[var(--tangerine-10)]/25 transition-all duration-1000\" data-kid=\"221\"></div>\n              <div class=\"relative z-10\" data-kid=\"222\">\n                <div class=\"w-16 h-16 glass rounded-2xl flex items-center justify-center mb-8 border border-white/10 group-hover:bg-white/15 transition-all\" data-kid=\"223\">\n                   <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-9 h-9 text-[var(--tangerine-10)]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"224\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" data-kid=\"225\"></path>\n                  </svg>\n                </div>\n                <h4 class=\"text-3xl font-extrabold text-white mb-4 font-heading tracking-tight\" data-kid=\"226\">Radiative Forcing Index</h4>\n                <p class=\"text-white/50 text-base leading-relaxed line-clamp-3 font-medium\" data-kid=\"227\">Impact of stratospheric aerosol variations on regional albedo. Significant deviations noted from the 2025 baseline models.</p>\n              </div>\n              <div class=\"flex justify-between items-center relative z-10\" data-kid=\"228\">\n                <div class=\"flex -space-x-3\" data-kid=\"229\">\n                  <img src=\"https://i.pravatar.cc/100?u=jen\" class=\"w-12 h-12 rounded-full border-2 border-[#1F305E] shadow-xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"230\">\n                </div>\n                <button class=\"px-8 py-4 glass text-white font-extrabold rounded-[1.5rem] text-[10px] uppercase tracking-[0.2em] hover:bg-white/15 transition-all border border-white/10\" data-kid=\"231\">Read Full Analysis</button>\n              </div>\n            </div>\n\n            \n            <div class=\"min-w-[460px] h-[400px] glass rounded-[3.5rem] p-12 flex flex-col justify-between shrink-0 snap-center relative overflow-hidden group hover:scale-[1.03] transition-all duration-700 border border-white/10 opacity-60 hover:opacity-100\" data-kid=\"232\">\n               <div class=\"absolute -right-20 -top-20 w-64 h-64 bg-[var(--baby-blue-30)]/10 rounded-full blur-[100px] group-hover:bg-[var(--baby-blue-30)]/25 transition-all duration-1000\" data-kid=\"233\"></div>\n              <div class=\"relative z-10\" data-kid=\"234\">\n                <div class=\"w-16 h-16 glass rounded-2xl flex items-center justify-center mb-8 border border-white/10 group-hover:bg-white/15 transition-all\" data-kid=\"235\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-9 h-9 text-[var(--baby-blue-30)]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"236\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 002-2V5a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\" data-kid=\"237\"></path>\n                  </svg>\n                </div>\n                <h4 class=\"text-3xl font-extrabold text-white mb-4 font-heading tracking-tight\" data-kid=\"238\">Precipitation Dynamics</h4>\n                <p class=\"text-white/50 text-base leading-relaxed line-clamp-3 font-medium\" data-kid=\"239\">Evaluating high-frequency radar reflections across the Scandinavian peninsula. Evidence suggests shifted rain belt patterns.</p>\n              </div>\n              <div class=\"flex justify-between items-center relative z-10\" data-kid=\"240\">\n                <div class=\"flex -space-x-3\" data-kid=\"241\">\n                  <img src=\"https://i.pravatar.cc/100?u=tom\" class=\"w-12 h-12 rounded-full border-2 border-[#1F305E] shadow-xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"242\">\n                  <img src=\"https://i.pravatar.cc/100?u=lucy\" class=\"w-12 h-12 rounded-full border-2 border-[#1F305E] shadow-xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"243\">\n                </div>\n                <button class=\"px-8 py-4 glass text-white font-extrabold rounded-[1.5rem] text-[10px] uppercase tracking-[0.2em] hover:bg-white/15 transition-all border border-white/10\" data-kid=\"244\">Read Full Analysis</button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"245\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"246\"></script>\n<script type=\"module\" data-kid=\"247\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Smooth Scroll Initialization\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    orientation: 'vertical',\n    gestureOrientation: 'vertical',\n    smoothWheel: true,\n  });\n\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // GSAP Animations\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Background Blobs Motion (Subtle)\n  gsap.to(\".blob-1\", { x: \"15%\", y: \"20%\", duration: 20, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n  gsap.to(\".blob-2\", { x: \"-20%\", y: \"-15%\", duration: 25, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n  gsap.to(\".blob-3\", { x: \"10%\", y: \"-25%\", duration: 18, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n  gsap.to(\".blob-4\", { x: \"25%\", y: \"15%\", duration: 30, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n\n  // Staggered Entry Reveal for the whole page\n  gsap.from(\".animate-header\", { \n    opacity: 0, \n    y: -30, \n    duration: 1.5, \n    ease: \"power4.out\" \n  });\n  \n  gsap.from(\".card-reveal\", {\n    opacity: 0,\n    y: 80,\n    duration: 1.2,\n    stagger: 0.1,\n    ease: \"power3.out\",\n    clearProps: \"all\", // Ensures CSS hovers work after animation\n    scrollTrigger: {\n      trigger: \"#dashboard-grid\",\n      start: \"top 85%\",\n    }\n  });\n\n  // Trend Chart Animation on Scroll\n  gsap.to(\".chart-path-final\", {\n    strokeDashoffset: 0,\n    duration: 3,\n    ease: \"power2.inOut\",\n    scrollTrigger: {\n      trigger: \"#trends\",\n      start: \"top 70%\",\n    }\n  });\n\n  // Carousel Navigation\n  const container = document.querySelector('.carousel-container');\n  const cardWidth = 500; // approximation including gap\n  \n  document.getElementById('carousel-next').addEventListener('click', () => {\n    container.scrollBy({ left: cardWidth, behavior: 'smooth' });\n  });\n  \n  document.getElementById('carousel-prev').addEventListener('click', () => {\n    container.scrollBy({ left: -cardWidth, behavior: 'smooth' });\n  });\n\n  // Handle Lenis scrolling for iframes / nested elements if needed\n  lenis.on('scroll', ScrollTrigger.update);\n</script>\n",
